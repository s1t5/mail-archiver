@using Microsoft.AspNetCore.Http.Extensions
@using MailArchiver.Services
@inject MailArchiver.Services.IAuthenticationService AuthService
@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.SearchViewModel
@{
    ViewData["Title"] = Localizer["EmailArchive"];
}

@* Anti-Forgery Token für JavaScript *@
@Html.AntiForgeryToken()

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">@Localizer["EmailArchive"]</h1>
        @* Mobile folder tree toggle button *@
        <button type="button" class="btn btn-outline-secondary folder-tree-mobile-toggle" data-bs-toggle="offcanvas" data-bs-target="#folderTreeOffcanvas">
            <i class="bi bi-folder"></i> <span>@Localizer["Folders"]</span>
        </button>
    </div>

    @* Active Jobs Alert *@
    @if (User.IsInRole("Admin") && ViewBag.ActiveJobsCount != null && ViewBag.ActiveJobsCount > 0)
    {
        <div class="alert alert-info alert-dismissible fade show alert-persistent">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
                <div>
                    <i class="bi bi-clock-history me-2"></i>
                    <strong>@Localizer["BackgroundJobsActive"]</strong> @string.Format(Localizer["BackgroundJobsActiveCount"].Value, ViewBag.ActiveJobsCount)
                </div>
                <div class="d-flex align-items-center gap-2">
                    <a asp-action="Jobs" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-eye me-1"></i> @Localizer["ViewJobs"]
                    </a>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header bg-light">
            <span class="h6 mb-0"><i class="bi bi-search me-1"></i>@Localizer["Search"]</span>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get" id="searchForm">
                <div class="row">
                    <div class="col-12 col-md-6 col-lg-3 mb-3">
                        <label asp-for="SelectedAccountId" class="form-label">@Localizer["Account"]</label>
                        <select asp-for="SelectedAccountId" asp-items="Model.AccountOptions" class="form-select form-select-sm" id="accountSelect"></select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-2 mb-3">
                        <label asp-for="IsOutgoing" class="form-label">@Localizer["Direction"]</label>
                        <select asp-for="IsOutgoing" asp-items="Model.DirectionOptions" class="form-select form-select-sm"></select>
                    </div>
                    <div class="col-6 col-md-3 col-lg-2 mb-3">
                        <label asp-for="FromDate" class="form-label">@Localizer["FromDate"]</label>
                        <input asp-for="FromDate" class="form-control form-control-sm" type="date" />
                    </div>
                    <div class="col-6 col-md-3 col-lg-2 mb-3">
                        <label asp-for="ToDate" class="form-label">@Localizer["ToDate"]</label>
                        <input asp-for="ToDate" class="form-control form-control-sm" type="date" />
                    </div>
                    <div class="col-6 col-md-3 col-lg-2 mb-3">
                        <label for="adv_attach" class="form-label">@Localizer["AdvAttachTitle"]</label>
                        <select id="adv_attach" class="form-select form-select-sm">
                            <option value="">@Localizer["AdvAttachAny"]</option>
                            <option value="yes">@Localizer["AdvAttachYes"]</option>
                            <option value="no">@Localizer["AdvAttachNo"]</option>
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12 mb-3">
                        <label asp-for="SearchTerm" class="form-label">@Localizer["SearchTerm"]</label>
                        <input asp-for="SearchTerm" class="form-control form-control-sm" placeholder="@Localizer["SubjectSender"]" />
                        <div class="form-text small text-muted">
                            <a class="text-decoration-none" data-bs-toggle="collapse" href="#advSearchHelp" role="button" aria-expanded="false" aria-controls="advSearchHelp">
                                <i class="bi bi-info-circle me-1"></i><strong>@Localizer["AdvancedSearch"]</strong> <i class="bi bi-chevron-down"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                                                    <div class="collapse mt-1" id="advSearchHelp">
                                <div class="card card-body p-2">
                                    <div id="adv_rows"></div>
                                    <div>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" id="adv_add_row"><i class="bi bi-plus-lg me-1"></i>@Localizer["AdvAddCondition"]</button>
                                    </div>
                                    <hr class="my-2">
                                    <div class="small text-muted">
                                        @Localizer["AdvancedSearchInfo0"]<br>
                                        @Localizer["AdvancedSearchInfo1"]<br>
                                        @Localizer["AdvancedSearchInfo2"]<br>
                                        @Localizer["AdvancedSearchInfo3"]<br>
                                        @Localizer["AdvancedSearchInfo4"]<br>
                                        @Localizer["AdvancedSearchInfo5"]<br>
                                        @Localizer["AdvBuilderQuoteHint"]<br>
                                        @Localizer["AdvBuilderCaseHint"]
                                    </div>
                                </div>
                            </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                            <div class="d-flex flex-wrap gap-2">
                                <button type="submit" class="btn btn-primary btn-sm" id="searchSubmitBtn">
                                    <i class="bi bi-search" id="searchSubmitIcon"></i>
                                    <span id="searchSubmitText">@Localizer["Search"]</span>
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">@Localizer["Reset"]</a>
                                <div class="form-check d-flex align-items-center ms-2">
                                    <input class="form-check-input me-2" type="checkbox" id="toggleSelectionMode" name="ShowSelectionControls" value="true"
                                           @(Model.ShowSelectionControls ? "checked" : "")>
                                    <label class="form-check-label small" for="toggleSelectionMode">@Localizer["SelectionMode"]</label>
                                    <input type="hidden" id="userTimezone" name="UserTimezone" value="" />
                                    <input type="hidden" id="pageSizeHidden" name="PageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="SelectedFolder" value="@Model.SelectedFolder" />
                                    <input type="hidden" name="SortBy" value="@Model.SortBy" />
                                    <input type="hidden" name="SortOrder" value="@Model.SortOrder" />
                                    <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* Batch Operation Information *@
    @if (Model.ShowSelectionControls)
    {
        <div class="card mb-4 border-info">
            <div class="card-header bg-light">
                <h6 class="mb-0 text-info">
                    <i class="bi bi-info-circle me-1"></i>@Localizer["BatchOperationInformation"]
                </h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-12 col-lg-8">
                        <div class="row">
                            <div class="col-12 col-md-4 mb-2">
                                <small class="text-muted d-block">@Localizer["DirectProcessing"]</small>
                                <strong class="text-success">1 - @ViewBag.AsyncThreshold emails</strong>
                                <small class="d-block text-muted">@Localizer["ProcessOnPage"]</small>
                            </div>
                            <div class="col-12 col-md-4 mb-2">
                                <small class="text-muted d-block">@Localizer["BackgroundJob"]</small>
                                <strong class="text-primary">@(ViewBag.AsyncThreshold + 1) - @ViewBag.MaxAsyncEmails.ToString("N0") emails</strong>
                                <small class="d-block text-muted">@Localizer["ProcessInBackground"]</small>
                            </div>
                            <div class="col-12 col-md-4 mb-2">
                                <small class="text-muted d-block">@Localizer["MaximumLimit"]</small>
                                <strong class="text-warning">@ViewBag.MaxAsyncEmails.ToString("N0") emails</strong>
                                <small class="d-block text-muted">@Localizer["SplitLargerOperations"]</small>
                            </div>
                        </div>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="col-12 col-lg-4">
                            <div class="d-flex flex-column gap-2">
                                @if (ViewBag.ActiveJobsCount != null && ViewBag.ActiveJobsCount > 0)
                                {
                                    <div class="alert alert-warning mb-2 p-2">
                                        <small>
                                            <i class="bi bi-clock-history me-1"></i>
                                            <strong>@ViewBag.ActiveJobsCount active job(s)</strong> currently running
                                        </small>
                                    </div>
                                    <a asp-action="Jobs" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-eye me-1"></i>@Localizer["MonitorBackgroundJobs"]
                                    </a>
                                }
                                else
                                {
                                    <small class="text-muted">
                                        <i class="bi bi-check-circle me-1 text-success"></i>
                                        @Localizer["NoBackgroundJobsRunning"]
                                    </small>
                                    <a asp-action="Jobs" class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-clock-history me-1"></i>@Localizer["ViewJobHistory"]
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* Folder Tree Panel - Desktop *@
    <div class="row">
        <div class="d-none d-lg-block" id="folderTreeColumn">
            <div class="folder-tree-panel" id="folderTreePanel">
                <div class="folder-tree-header" id="folderTreeHeader" role="button" tabindex="0" title="@Localizer["ToggleFolderTree"]">
                    <div class="d-flex align-items-center">
                        <i class="bi bi-folder me-2"></i><span class="folder-tree-header-text">@Localizer["Folders"]</span>
                    </div>
                    <i class="bi bi-chevron-down folder-tree-collapse-icon" id="folderTreeCollapseIcon"></i>
                </div>
                <div class="folder-tree-content" id="folderTreeContent">
                    @if (Model.FolderTree != null && Model.FolderTree.Any())
                    {
                        @await Html.PartialAsync("_FolderTree", Model.FolderTree, new ViewDataDictionary(ViewData) { { "SelectedFolder", Model.SelectedFolder } })
                    }
                    else
                    {
                        <div class="folder-tree-empty">
                            <i class="bi bi-folder2-open d-block mb-2" style="font-size: 1.5rem;"></i>
                            <span class="text-muted">@Localizer["NoFolders"]</span>
                        </div>
                    }
                </div>
                <div class="folder-tree-resize-handle" id="folderTreeResizeHandle"></div>
            </div>
        </div>
        <div class="folder-tree-result-col">
            @if (Model.SearchResults != null && Model.SearchResults.Any())
            {
                <div class="card">
                    <div class="card-header bg-light">
                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
                            <div class="d-flex align-items-center gap-2">
                                <button type="button" class="btn btn-outline-secondary btn-sm folder-tree-toggle-btn" id="folderTreeToggleBtn" title="@Localizer["ToggleFolderTree"]" style="display: none;">
                                    <i class="bi bi-folder me-1"></i><i class="bi bi-chevron-right"></i>
                                </button>
                                <span class="small"><strong>@Model.TotalResults</strong> @Localizer["EmailsFound", ""]</span>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="small">@Localizer["PageOf", Model.PageNumber, Model.TotalPages]</span>
                                <select asp-for="PageSize" asp-items="Model.PageSizeOptions" class="form-select form-select-sm" id="pageSizeSelect" style="width: 80px;"></select>
                            </div>
                        </div>
                    </div>
                    
                    @if (Model.ShowSelectionControls)
                    {
                        <div class="p-2 bg-light border-bottom">
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-2">
                                <div class="d-flex flex-wrap gap-2 align-items-center">
                                    <button type="button" id="selectAllBtn" class="btn btn-sm btn-outline-primary">@Localizer["SelectAll"]</button>
                                    <button type="button" id="deselectAllBtn" class="btn btn-sm btn-outline-secondary">@Localizer["DeselectAll"]</button>
                                    <span id="selectionCounter" class="badge bg-primary">0 selected</span>
                                    <span id="operationMode" class="badge bg-info" style="display:none;"></span>
                                </div>
                                <div id="selectionActions" style="display:none;">
                                    <button type="button" id="batchRestoreBtn" class="btn btn-sm btn-success me-2">
                                        <i class="bi bi-envelope-arrow-up"></i>
                                        <span class="d-inline">@Localizer["CopySelected"]</span>
                                    </button>
                                    <button type="button" id="exportSelectedBtn" class="btn btn-sm btn-primary me-2">
                                        <i class="bi bi-download"></i>
                                        <span class="d-inline">@Localizer["ExportSelected"]</span>
                                    </button>
                                    @if (User.IsInRole("Admin") || User.IsInRole("SelfManager"))
                                    {
                                        <button type="button" id="deleteSelectedBtn" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                            <span class="d-inline">@Localizer["DeleteSelected"]</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Desktop Table -->
                    <div class="card-body p-0 d-none d-lg-block">
                        <div class="table-responsive">
                            <table class="table table-hover table-striped table-sm mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        @if (Model.ShowSelectionControls)
                                        {
                                            <th style="width: 50px;">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="selectAllCheckbox">
                                                </div>
                                            </th>
                                        }
                                        <th style="cursor: pointer;" onclick="window.location.href='@Url.Action("Index", new { SearchTerm = Model.SearchTerm, FromDate = Model.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.ToDate?.ToString("yyyy-MM-dd"), SelectedAccountId = Model.SelectedAccountId, SelectedFolder = Model.SelectedFolder, IsOutgoing = Model.IsOutgoing, PageNumber = 1, PageSize = Model.PageSize, ShowSelectionControls = Model.ShowSelectionControls, SortBy = "Subject", SortOrder = (Model.SortBy == "Subject" && Model.SortOrder == "asc") ? "desc" : "asc" })'">
                                            @Localizer["Subject"]
                                            @if (Model.SortBy == "Subject")
                                            {
                                                <i class="bi bi-@(Model.SortOrder == "asc" ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th style="cursor: pointer;" onclick="window.location.href='@Url.Action("Index", new { SearchTerm = Model.SearchTerm, FromDate = Model.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.ToDate?.ToString("yyyy-MM-dd"), SelectedAccountId = Model.SelectedAccountId, SelectedFolder = Model.SelectedFolder, IsOutgoing = Model.IsOutgoing, PageNumber = 1, PageSize = Model.PageSize, ShowSelectionControls = Model.ShowSelectionControls, SortBy = "From", SortOrder = (Model.SortBy == "From" && Model.SortOrder == "asc") ? "desc" : "asc" })'">
                                            @Localizer["From"]
                                            @if (Model.SortBy == "From")
                                            {
                                                <i class="bi bi-@(Model.SortOrder == "asc" ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th style="cursor: pointer;" onclick="window.location.href='@Url.Action("Index", new { SearchTerm = Model.SearchTerm, FromDate = Model.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.ToDate?.ToString("yyyy-MM-dd"), SelectedAccountId = Model.SelectedAccountId, SelectedFolder = Model.SelectedFolder, IsOutgoing = Model.IsOutgoing, PageNumber = 1, PageSize = Model.PageSize, ShowSelectionControls = Model.ShowSelectionControls, SortBy = "To", SortOrder = (Model.SortBy == "To" && Model.SortOrder == "asc") ? "desc" : "asc" })'">
                                            @Localizer["To"]
                                            @if (Model.SortBy == "To")
                                            {
                                                <i class="bi bi-@(Model.SortOrder == "asc" ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th style="cursor: pointer;" onclick="window.location.href='@Url.Action("Index", new { SearchTerm = Model.SearchTerm, FromDate = Model.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.ToDate?.ToString("yyyy-MM-dd"), SelectedAccountId = Model.SelectedAccountId, SelectedFolder = Model.SelectedFolder, IsOutgoing = Model.IsOutgoing, PageNumber = 1, PageSize = Model.PageSize, ShowSelectionControls = Model.ShowSelectionControls, SortBy = "SentDate", SortOrder = (Model.SortBy == "SentDate" && Model.SortOrder == "asc") ? "desc" : "asc" })'">
                                            @Localizer["Date"]
                                            @if (Model.SortBy == "SentDate")
                                            {
                                                <i class="bi bi-@(Model.SortOrder == "asc" ? "arrow-up" : "arrow-down")"></i>
                                            }
                                        </th>
                                        <th>@Localizer["Account"]</th>
                                        <th>@Localizer["Status"]</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var email in Model.SearchResults)
                                    {
                                        <tr>
                                            @if (Model.ShowSelectionControls)
                                            {
                                                <td>
                                                    <div class="form-check">
                                                        <input class="form-check-input email-select-checkbox" type="checkbox" name="ids" value="@email.Id">
                                                    </div>
                                                </td>
                                            }
                                            <td>
                                                @if (email.IsOutgoing)
                                                {
                                                    <span class="badge bg-info">@Localizer["Out"]</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@Localizer["In"]</span>
                                                }
                                                @email.Subject
                                            </td>
                                            <td>@email.From</td>
                                            <td>@email.To</td>
                                            <td>@email.SentDate.ToString("g")</td>
                                            <td>@email.MailAccount.Name</td>
                                            <td>
                                                @if (email.HasAttachments)
                                                {
                                                    <i class="bi bi-paperclip text-warning" title="@Localizer["HasAttachments"]"></i>
                                                }
                                            </td>
                                            <td>
                                                <a asp-action="Details" asp-route-id="@email.Id" asp-route-returnUrl="@Context.Request.GetDisplayUrl()" class="btn btn-sm btn-outline-primary">@Localizer["Details"]</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Mobile Cards -->
                    <div class="d-lg-none p-3">
                        @foreach (var email in Model.SearchResults)
                        {
                            <div class="card mb-3 email-card-mobile">
                                @if (Model.ShowSelectionControls)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input email-select-checkbox" type="checkbox" name="ids" value="@email.Id" id="email-mobile-@email.Id">
                                        <label class="form-check-label" for="email-mobile-@email.Id">@Localizer["SelectThisEmail"]</label>
                                    </div>
                                }
                                <div class="card-body p-3">
                                    <div class="email-card-header">
                                        <div class="email-card-title">
                                            @if (email.IsOutgoing)
                                            {
                                                <i class="bi bi-arrow-up-right text-primary me-1"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-arrow-down-left text-success me-1"></i>
                                            }
                                            @email.Subject
                                            @if (email.HasAttachments)
                                            {
                                                <i class="bi bi-paperclip text-warning ms-1" title="@Localizer["HasAttachments"]"></i>
                                            }
                                        </div>
                                    </div>
                                    <div class="email-card-meta">
                                        <div><strong>@Localizer["From"]:</strong> @email.From</div>
                                        <div><strong>@Localizer["To"]:</strong> @(email.To.Length > 50 ? email.To.Substring(0, 50) + "..." : email.To)</div>
                                        <div><strong>@Localizer["Date"]:</strong> @email.SentDate.ToString("g")</div>
                                        <div><strong>@Localizer["Account"]:</strong> @email.MailAccount.Name</div>
                                    </div>
                                    <div class="email-card-actions">
                                        <a asp-action="Details" asp-route-id="@email.Id" asp-route-returnUrl="@Context.Request.GetDisplayUrl()" class="btn btn-outline-primary btn-sm w-100">
                                            <i class="bi bi-eye"></i> @Localizer["Details"]
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    <div class="card-footer">
                        <nav>
                            <ul class="pagination pagination-sm justify-content-center mb-0">
                                @if (Model.PageNumber > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action("Index", new { SearchTerm = Model.SearchTerm, FromDate = Model.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.ToDate?.ToString("yyyy-MM-dd"), SelectedAccountId = Model.SelectedAccountId, SelectedFolder = Model.SelectedFolder, IsOutgoing = Model.IsOutgoing, PageNumber = Model.PageNumber - 1, PageSize = Model.PageSize, ShowSelectionControls = Model.ShowSelectionControls, SortBy = Model.SortBy, SortOrder = Model.SortOrder })">@Localizer["Previous"]</a>
                                    </li>
                                }
                                @{
                                    var startPage = Math.Max(1, Model.PageNumber - 1);
                                    var endPage = Math.Min(Model.TotalPages, Model.PageNumber + 1);
                                }
                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { SearchTerm = Model.SearchTerm, FromDate = Model.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.ToDate?.ToString("yyyy-MM-dd"), SelectedAccountId = Model.SelectedAccountId, SelectedFolder = Model.SelectedFolder, IsOutgoing = Model.IsOutgoing, PageNumber = i, PageSize = Model.PageSize, ShowSelectionControls = Model.ShowSelectionControls, SortBy = Model.SortBy, SortOrder = Model.SortOrder })">@i</a>
                                    </li>
                                }
                                @if (Model.PageNumber < Model.TotalPages)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action("Index", new { SearchTerm = Model.SearchTerm, FromDate = Model.FromDate?.ToString("yyyy-MM-dd"), ToDate = Model.ToDate?.ToString("yyyy-MM-dd"), SelectedAccountId = Model.SelectedAccountId, SelectedFolder = Model.SelectedFolder, IsOutgoing = Model.IsOutgoing, PageNumber = Model.PageNumber + 1, PageSize = Model.PageSize, ShowSelectionControls = Model.ShowSelectionControls, SortBy = Model.SortBy, SortOrder = Model.SortOrder })">@Localizer["Next"]</a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    </div>
                </div>
            }
            else if (Model.SearchResults != null)
            {
                <div class="text-center py-5">
                    <div class="mb-3">
                        <i class="bi bi-search display-1 text-muted"></i>
                    </div>
                    <h5 class="text-muted">@Localizer["NoEmailsFoundTitle"]</h5>
                    <p class="text-muted">@Localizer["NoEmailsFoundText"]</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Mobile Folder Tree Offcanvas -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="folderTreeOffcanvas" aria-labelledby="folderTreeOffcanvasLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="folderTreeOffcanvasLabel">
            <i class="bi bi-folder me-2"></i>@Localizer["Folders"]
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-0">
        <div class="folder-tree-content" id="folderTreeContentMobile">
            @if (Model.FolderTree != null && Model.FolderTree.Any())
            {
                @await Html.PartialAsync("_FolderTree", Model.FolderTree, new ViewDataDictionary(ViewData) { { "SelectedFolder", Model.SelectedFolder } })
            }
            else
            {
                <div class="folder-tree-empty">
                    <i class="bi bi-folder2-open d-block mb-2" style="font-size: 1.5rem;"></i>
                    <span class="text-muted">@Localizer["NoFolders"]</span>
                </div>
            }
        </div>
    </div>
</div>

<!-- Batch Restore Confirmation Modal -->
<div class="modal fade" id="batchRestoreConfirmModal" tabindex="-1" aria-labelledby="batchRestoreConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="batchRestoreConfirmModalLabel">@Localizer["ConfirmBatchRestore"]</h5>
                <span id="batchRestoreConfirmModalTitleText" style="display:none;">@Localizer["ConfirmBatchRestore"]</span>
                <span id="batchDeleteConfirmModalTitleText" style="display:none;">@Localizer["ConfirmBatchDelete"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="confirmMessage"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                <button type="button" class="btn btn-primary" id="confirmBatchRestoreBtn">@Localizer["Continue"]</button>
            </div>
        </div>
    </div>
</div>

<!-- Export Format Selection Modal -->
<div class="modal fade" id="exportFormatModal" tabindex="-1" aria-labelledby="exportFormatModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportFormatModalLabel">@Localizer["ExportSelected"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <h6>@Localizer["ExportFormatSelection"]</h6>
                    <p class="text-muted small">@Localizer["ExportFormatSelectionInfo"]</p>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="exportFormat" id="formatEML" value="EML" checked>
                                    <label class="form-check-label" for="formatEML"><strong>@Localizer["EMLFormat"]</strong></label>
                                </div>
                                <small class="text-muted">@Localizer["EMLFormatDescription"]</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="exportFormat" id="formatMBox" value="MBox">
                                    <label class="form-check-label" for="formatMBox"><strong>@Localizer["MBoxFormat"]</strong></label>
                                </div>
                                <small class="text-muted">@Localizer["MBoxFormatDescription"]</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="alert alert-info">
                    <small><i class="bi bi-info-circle me-1"></i>@Localizer["ExportSelectedInfo"]</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                <button type="button" class="btn btn-primary" id="confirmExportBtn">@Localizer["StartExport"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        console.log("Email archive page initialized");
        const timezoneInput = document.getElementById('userTimezone');
        if (timezoneInput) {
            timezoneInput.value = Intl.DateTimeFormat().resolvedOptions().timeZone;
        }

        // Aktuelle Formulareingaben (ggf. ungespeichert) in URL uebernehmen,
        // damit Suchbegriff/Datum/Direction beim Account- oder Ordnerwechsel erhalten bleiben.
        function mergeFormValuesIntoUrl(url, form) {
            const formData = new FormData(form);
            for (const [key, value] of formData.entries()) {
                if (value !== '') {
                    url.searchParams.set(key, value);
                } else {
                    url.searchParams.delete(key);
                }
            }
        }

        // Auto-submit form when page size changes
        const pageSizeSelect = document.getElementById('pageSizeSelect');
        const pageSizeHidden = document.getElementById('pageSizeHidden');
        if (pageSizeSelect && pageSizeHidden) {
            pageSizeSelect.addEventListener('change', function() {
                pageSizeHidden.value = this.value;
                searchForm.submit();
            });
        }

        // Account selection change handler - now updates folder tree via AJAX
        const accountSelect = document.getElementById('accountSelect');
        
        if (accountSelect) {
            accountSelect.addEventListener('change', function() {
                const accountId = this.value;
                // Reload page with new account selection to update folder tree
                const url = new URL(window.location.href);
                mergeFormValuesIntoUrl(url, searchForm);
                if (accountId && accountId !== '') {
                    url.searchParams.set('SelectedAccountId', accountId);
                } else {
                    url.searchParams.delete('SelectedAccountId');
                }
                url.searchParams.delete('SelectedFolder');
                url.searchParams.set('PageNumber', '1');
                window.location.href = url.toString();
            });
        }

        // Folder Tree Panel Collapse/Expand functionality
        const FOLDER_TREE_COLLAPSED_KEY = 'folderTreeCollapsed';
        const folderTreePanel = document.getElementById('folderTreePanel');
        const folderTreeHeader = document.getElementById('folderTreeHeader');
        const folderTreeColumn = document.getElementById('folderTreeColumn');

        function isFolderTreeCollapsed() {
            return localStorage.getItem(FOLDER_TREE_COLLAPSED_KEY) === 'true';
        }

        function saveFolderTreeState(collapsed) {
            try { localStorage.setItem(FOLDER_TREE_COLLAPSED_KEY, collapsed.toString()); } catch (e) {}
        }

        function toggleFolderTree() {
            const isCollapsed = folderTreePanel.classList.toggle('collapsed');
            folderTreeColumn.classList.toggle('collapsed-col', isCollapsed);
            saveFolderTreeState(isCollapsed);
        }

        function initializeFolderTreeState() {
            if (isFolderTreeCollapsed()) {
                folderTreePanel.classList.add('collapsed');
                folderTreeColumn.classList.add('collapsed-col');
            }
        }

        // Toggle button in table header
        const folderTreeToggleBtn = document.getElementById('folderTreeToggleBtn');
        
        function updateToggleBtnState() {
            if (folderTreeToggleBtn && folderTreePanel) {
                const isCollapsed = folderTreePanel.classList.contains('collapsed');
                folderTreeToggleBtn.classList.toggle('collapsed', isCollapsed);
                // Show button only when folder tree is collapsed
                folderTreeToggleBtn.style.display = isCollapsed ? 'inline-block' : 'none';
            }
        }

        // Initialize folder tree state on page load
        if (folderTreePanel && folderTreeColumn) {
            initializeFolderTreeState();
            
            // Update toggle button state after initializing folder tree state
            updateToggleBtnState();
            
            // Click handler for header in folder tree panel
            if (folderTreeHeader) {
                folderTreeHeader.addEventListener('click', function(e) {
                    e.stopPropagation();
                    toggleFolderTree();
                    updateToggleBtnState();
                });
                
                // Keyboard support
                folderTreeHeader.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        toggleFolderTree();
                        updateToggleBtnState();
                    }
                });
            }
        }
        
        if (folderTreeToggleBtn) {
            folderTreeToggleBtn.addEventListener('click', function() {
                toggleFolderTree();
                updateToggleBtnState();
            });
        }

        // Folder tree click handler
        function initializeFolderTree() {
            document.querySelectorAll('.folder-tree-item').forEach(function(item) {
                item.addEventListener('click', function(e) {
                    if (e.target.closest('.folder-tree-toggle')) {
                        return; // Let toggle handle expand/collapse
                    }
                    const folder = this.dataset.folder;
                    if (folder) {
                        const url = new URL(window.location.href);
                        mergeFormValuesIntoUrl(url, searchForm);
                        url.searchParams.set('SelectedFolder', folder);
                        url.searchParams.set('PageNumber', '1');
                        window.location.href = url.toString();
                    }
                });
            });
            
            // Toggle expand/collapse
            document.querySelectorAll('.folder-tree-toggle').forEach(function(toggle) {
                toggle.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const parent = this.closest('.folder-tree-item');
                    const children = parent.querySelector('.folder-tree-children');
                    if (children) {
                        children.style.display = children.style.display === 'none' ? '' : 'none';
                        this.classList.toggle('expanded');
                    }
                });
            });
        }
        initializeFolderTree();

        // Resizable folder tree panel
        (function() {
            const FOLDER_TREE_WIDTH_KEY = 'folderTreeWidth';
            const resizeHandle = document.getElementById('folderTreeResizeHandle');
            const folderTreeColumn = document.getElementById('folderTreeColumn');
            let isResizing = false;

            // Restore saved width on page load
            function restoreFolderTreeWidth() {
                try {
                    const savedWidth = localStorage.getItem(FOLDER_TREE_WIDTH_KEY);
                    if (savedWidth && folderTreeColumn) {
                        const width = parseInt(savedWidth, 10);
                        if (!isNaN(width) && width >= 180 && width <= 600) {
                            folderTreeColumn.style.setProperty('--folder-tree-width', width + 'px');
                        }
                    }
                } catch (e) {}
            }

            restoreFolderTreeWidth();

            if (resizeHandle && folderTreeColumn) {
                resizeHandle.addEventListener('mousedown', function(e) {
                    e.preventDefault();
                    isResizing = true;
                    document.body.classList.add('resizing-folder-tree');
                    resizeHandle.classList.add('active');
                });
            }

            document.addEventListener('mousemove', function(e) {
                if (!isResizing || !folderTreeColumn) return;
                
                // Calculate new width relative to the parent row
                const row = folderTreeColumn.parentElement;
                const rowRect = row.getBoundingClientRect();
                const newWidth = e.clientX - rowRect.left;
                
                // Clamp between min (180px) and max (600px)
                const clampedWidth = Math.max(180, Math.min(600, newWidth));
                
                folderTreeColumn.style.setProperty('--folder-tree-width', clampedWidth + 'px');
            });

            document.addEventListener('mouseup', function() {
                if (isResizing) {
                    isResizing = false;
                    document.body.classList.remove('resizing-folder-tree');
                    if (resizeHandle) resizeHandle.classList.remove('active');
                    
                    // Save width to localStorage
                    if (folderTreeColumn) {
                        const currentWidth = parseInt(folderTreeColumn.style.getPropertyValue('--folder-tree-width'), 10);
                        if (!isNaN(currentWidth)) {
                            try {
                                localStorage.setItem(FOLDER_TREE_WIDTH_KEY, currentWidth.toString());
                            } catch (e) {}
                        }
                    }
                }
            });
        })();

        // Selection mode and batch operations
        const asyncThreshold = @ViewBag.AsyncThreshold;
        const maxAsyncEmails = @ViewBag.MaxAsyncEmails;
        const maxSelectableEmails = @(ViewBag.MaxSelectableEmails ?? 250);
        const STORAGE_KEY = 'emailSelection';

        // Localized strings emitted as JS string literals to avoid HTML-encoding of
        // special characters (e.g. apostrophes in "Tâche d'arrière-plan") inside <script>.
        const i18n = {
            maxSelectionsReached: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["MaxSelectionsReached"].Value)),
            selectedOf: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["SelectedOf"].Value)),
            directProcessingMode: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["DirectProcessingMode"].Value)),
            backgroundJobMode: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["BackgroundJobMode"].Value)),
            tooManySelected: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["TooManySelected"].Value)),
            copySelected: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["CopySelected"].Value)),
            pleaseSelectAtLeastOne: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PleaseSelectAtLeastOne"].Value)),
            tooManyEmailsSelected: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["TooManyEmailsSelected"].Value)),
            continueWithOperation: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ContinueWithOperation"].Value)),
            deleteSelectedEmailsConfirm: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["DeleteSelectedEmailsConfirm"].Value)),
            loading: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Loading"].Value))
        };
        
        const toggleSelectionMode = document.getElementById('toggleSelectionMode');
        const searchForm = document.getElementById('searchForm');
        const searchSubmitBtn = document.getElementById('searchSubmitBtn');
        const searchSubmitIcon = document.getElementById('searchSubmitIcon');
        const searchSubmitText = document.getElementById('searchSubmitText');
        const selectAllCheckbox = document.getElementById('selectAllCheckbox');
        const selectAllBtn = document.getElementById('selectAllBtn');
        const deselectAllBtn = document.getElementById('deselectAllBtn');
        const selectionCounter = document.getElementById('selectionCounter');
        const selectionActions = document.getElementById('selectionActions');
        const batchRestoreBtn = document.getElementById('batchRestoreBtn');
        const operationMode = document.getElementById('operationMode');

        // Show a spinner on the search submit button while the search request is in flight.
        // The form is a normal GET navigation, so the new page load replaces this one; the
        // spinner only needs to cover the time until the browser starts rendering the response.
        if (searchForm && searchSubmitBtn) {
            searchForm.addEventListener('submit', function () {
                if (searchSubmitIcon) searchSubmitIcon.style.display = 'none';
                if (searchSubmitText) searchSubmitText.textContent = i18n.loading;
                const spinner = document.createElement('span');
                spinner.className = 'spinner-border spinner-border-sm me-1';
                spinner.setAttribute('role', 'status');
                spinner.setAttribute('aria-hidden', 'true');
                searchSubmitBtn.prepend(spinner);
                searchSubmitBtn.disabled = true;
            });
        }

        function getStoredSelections() {
            try {
                const stored = localStorage.getItem(STORAGE_KEY);
                return stored ? JSON.parse(stored) : [];
            } catch (e) { return []; }
        }

        function saveStoredSelections(selections) {
            try { localStorage.setItem(STORAGE_KEY, JSON.stringify(selections)); } catch (e) {}
        }

        function addToStoredSelections(emailIds) {
            const stored = getStoredSelections();
            const updated = [...new Set([...stored, ...emailIds])];
            if (updated.length > maxSelectableEmails) {
                alert(i18n.maxSelectionsReached.replace('{0}', maxSelectableEmails));
                return false;
            }
            saveStoredSelections(updated);
            return true;
        }

        function removeFromStoredSelections(emailIds) {
            const stored = getStoredSelections();
            saveStoredSelections(stored.filter(id => !emailIds.includes(id)));
        }

        function clearStoredSelections() { localStorage.removeItem(STORAGE_KEY); }
        function getTotalSelectedCount() { return getStoredSelections().length; }

        function updateSelectionCounter() {
            const totalSelected = getTotalSelectedCount();
            const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
            const checkedBoxes = document.querySelectorAll('.email-select-checkbox:checked');
            
            if (selectionCounter) {
                if (totalSelected >= maxSelectableEmails) {
                    selectionCounter.innerHTML = i18n.maxSelectionsReached.replace('{0}', maxSelectableEmails);
                    selectionCounter.className = 'badge bg-warning';
                } else {
                    selectionCounter.innerHTML = i18n.selectedOf.replace('{0}', totalSelected).replace('{1}', maxSelectableEmails);
                    selectionCounter.className = 'badge bg-primary';
                }
            }

            if (operationMode && totalSelected > 0) {
                operationMode.style.display = 'inline';
                if (totalSelected <= asyncThreshold) {
                    operationMode.textContent = i18n.directProcessingMode;
                    operationMode.className = 'badge bg-success';
                } else if (totalSelected <= maxAsyncEmails) {
                    operationMode.textContent = i18n.backgroundJobMode;
                    operationMode.className = 'badge bg-primary';
                } else {
                    operationMode.textContent = i18n.tooManySelected;
                    operationMode.className = 'badge bg-danger';
                }
            } else if (operationMode) {
                operationMode.style.display = 'none';
            }

            if (selectionActions) {
                selectionActions.style.display = totalSelected > 0 ? 'block' : 'none';
                if (batchRestoreBtn && totalSelected > 0) {
                    if (totalSelected > maxAsyncEmails) {
                        batchRestoreBtn.disabled = true;
                        batchRestoreBtn.innerHTML = '<i class="bi bi-exclamation-triangle"></i> <span class="d-inline">' + i18n.tooManySelected + '</span>';
                        batchRestoreBtn.className = 'btn btn-sm btn-danger me-2';
                    } else {
                        batchRestoreBtn.disabled = false;
                        batchRestoreBtn.innerHTML = '<i class="bi bi-envelope-arrow-up"></i> <span class="d-inline">' + i18n.copySelected + '</span>';
                        batchRestoreBtn.className = 'btn btn-sm btn-success me-2';
                    }
                }
            }

            if (selectAllCheckbox && emailCheckboxes.length > 0) {
                selectAllCheckbox.checked = checkedBoxes.length === emailCheckboxes.length;
                selectAllCheckbox.indeterminate = checkedBoxes.length > 0 && checkedBoxes.length < emailCheckboxes.length;
            }
        }

        function initializeSelectionHandlers() {
            const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
            const storedSelections = getStoredSelections();
            emailCheckboxes.forEach(function(checkbox) {
                if (storedSelections.includes(checkbox.value)) checkbox.checked = true;
                checkbox.addEventListener('change', function() {
                    if (this.checked) {
                        if (!addToStoredSelections([this.value])) this.checked = false;
                    } else {
                        removeFromStoredSelections([this.value]);
                    }
                    updateSelectionCounter();
                });
            });
            updateSelectionCounter();
        }

        if (toggleSelectionMode) {
            toggleSelectionMode.addEventListener('change', function() {
                clearStoredSelections();
                searchForm.submit();
            });
        }

        if (selectAllCheckbox) {
            selectAllCheckbox.addEventListener('change', function() {
                const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
                const currentPageIds = Array.from(emailCheckboxes).map(cb => cb.value);
                if (this.checked) {
                    if (addToStoredSelections(currentPageIds)) {
                        emailCheckboxes.forEach(cb => cb.checked = true);
                    } else { this.checked = false; }
                } else {
                    removeFromStoredSelections(currentPageIds);
                    emailCheckboxes.forEach(cb => cb.checked = false);
                }
                updateSelectionCounter();
            });
        }

        if (selectAllBtn) {
            selectAllBtn.addEventListener('click', function() {
                const emailCheckboxes = document.querySelectorAll('.email-select-checkbox');
                const currentPageIds = Array.from(emailCheckboxes).map(cb => cb.value);
                const storedSelections = getStoredSelections();
                const currentPageSelected = currentPageIds.filter(id => storedSelections.includes(id));
                if (currentPageSelected.length === currentPageIds.length) {
                    removeFromStoredSelections(currentPageIds);
                    emailCheckboxes.forEach(cb => cb.checked = false);
                } else {
                    if (addToStoredSelections(currentPageIds)) {
                        emailCheckboxes.forEach(cb => cb.checked = true);
                    }
                }
                updateSelectionCounter();
            });
        }

        if (deselectAllBtn) {
            deselectAllBtn.addEventListener('click', function() {
                clearStoredSelections();
                document.querySelectorAll('.email-select-checkbox').forEach(cb => cb.checked = false);
                updateSelectionCounter();
            });
        }

        if (batchRestoreBtn) {
            batchRestoreBtn.addEventListener('click', function() {
                if (this.disabled) return;
                const totalSelected = getTotalSelectedCount();
                const storedSelections = getStoredSelections();
                if (totalSelected === 0) {
                    document.getElementById('confirmMessage').textContent = i18n.pleaseSelectAtLeastOne;
                    var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                    document.getElementById('confirmBatchRestoreBtn').style.display = 'none';
                    confirmModal.show();
                    setTimeout(function() { confirmModal.hide(); }, 3000);
                    return;
                }
                if (totalSelected > maxAsyncEmails) {
                    document.getElementById('confirmMessage').innerHTML = i18n.tooManyEmailsSelected.replace('{0}', totalSelected.toLocaleString()).replace('{1}', maxAsyncEmails.toLocaleString());
                    var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                    document.getElementById('confirmBatchRestoreBtn').style.display = 'none';
                    confirmModal.show();
                    setTimeout(function() { confirmModal.hide(); }, 5000);
                    return;
                }
                // Set modal title for batch restore
                document.getElementById('batchRestoreConfirmModalLabel').textContent = document.getElementById('batchRestoreConfirmModalTitleText').textContent;
                if (totalSelected > asyncThreshold) {
                    document.getElementById('confirmMessage').innerHTML = i18n.continueWithOperation.replace('{0}', totalSelected.toLocaleString());
                    var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                    document.getElementById('confirmBatchRestoreBtn').style.display = 'inline-block';
                    document.getElementById('confirmBatchRestoreBtn').onclick = function() {
                        confirmModal.hide();
                        submitBatchRestoreForm(storedSelections);
                    };
                    confirmModal.show();
                    return;
                }
                submitBatchRestoreForm(storedSelections);
            });
        }

        function submitBatchRestoreForm(selectedIds) {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = '@Url.Action("BatchRestoreStart", "Emails")';
            form.appendChild(createHiddenInput('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value));
            form.appendChild(createHiddenInput('returnUrl', '@Context.Request.Path@Context.Request.QueryString'));
            selectedIds.forEach(id => form.appendChild(createHiddenInput('ids', id)));
            document.body.appendChild(form);
            form.submit();
        }

        function createHiddenInput(name, value) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = name;
            input.value = value;
            return input;
        }

        const exportSelectedBtn = document.getElementById('exportSelectedBtn');
        if (exportSelectedBtn) {
            exportSelectedBtn.addEventListener('click', function() {
                if (getTotalSelectedCount() === 0) {
                    document.getElementById('confirmMessage').textContent = i18n.pleaseSelectAtLeastOne;
                    var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                    document.getElementById('confirmBatchRestoreBtn').style.display = 'none';
                    confirmModal.show();
                    setTimeout(function() { confirmModal.hide(); }, 3000);
                    return;
                }
                var exportFormatModal = new bootstrap.Modal(document.getElementById('exportFormatModal'));
                exportFormatModal.show();
                window.selectedEmailsForExport = getStoredSelections();
            });
        }

        const confirmExportBtn = document.getElementById('confirmExportBtn');
        if (confirmExportBtn) {
            confirmExportBtn.addEventListener('click', function() {
                const selectedFormat = document.querySelector('input[name="exportFormat"]:checked').value;
                bootstrap.Modal.getInstance(document.getElementById('exportFormatModal')).hide();
                submitExportForm(window.selectedEmailsForExport, selectedFormat);
            });
        }

        function submitExportForm(selectedIds, selectedFormat) {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = '@Url.Action("ExportSelected", "Emails")';
            form.appendChild(createHiddenInput('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value));
            form.appendChild(createHiddenInput('format', selectedFormat));
            form.appendChild(createHiddenInput('returnUrl', '@Context.Request.Path@Context.Request.QueryString'));
            selectedIds.forEach(id => form.appendChild(createHiddenInput('ids', id)));
            document.body.appendChild(form);
            form.submit();
        }

        const deleteSelectedBtn = document.getElementById('deleteSelectedBtn');
        if (deleteSelectedBtn) {
            deleteSelectedBtn.addEventListener('click', function() {
                if (getTotalSelectedCount() === 0) {
                    document.getElementById('confirmMessage').textContent = i18n.pleaseSelectAtLeastOne;
                    var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                    document.getElementById('confirmBatchRestoreBtn').style.display = 'none';
                    confirmModal.show();
                    setTimeout(function() { confirmModal.hide(); }, 3000);
                    return;
                }
                // Set modal title for batch delete
                document.getElementById('batchRestoreConfirmModalLabel').textContent = document.getElementById('batchDeleteConfirmModalTitleText').textContent;
                document.getElementById('confirmMessage').innerHTML = i18n.deleteSelectedEmailsConfirm.replace('{0}', getTotalSelectedCount().toLocaleString());
                var confirmModal = new bootstrap.Modal(document.getElementById('batchRestoreConfirmModal'));
                document.getElementById('confirmBatchRestoreBtn').style.display = 'inline-block';
                document.getElementById('confirmBatchRestoreBtn').onclick = function() {
                    confirmModal.hide();
                    submitDeleteForm(getStoredSelections());
                };
                confirmModal.show();
            });
        }

        function submitDeleteForm(selectedIds) {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = '@Url.Action("DeleteSelected", "Emails")';
            form.appendChild(createHiddenInput('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value));
            form.appendChild(createHiddenInput('returnUrl', '@Context.Request.Path@Context.Request.QueryString'));
            selectedIds.forEach(id => form.appendChild(createHiddenInput('ids', id)));
            document.body.appendChild(form);
            form.submit();
        }

        @if (Model.ShowSelectionControls)
        {
            <text>initializeSelectionHandlers();</text>
        }

        // Advanced-Suche: Zeilen-Builder. Jede Zeile = optionaler UND/ODER-Konnektor (ausser der ersten)
        // + Feld (Alle/Betreff/Von/An/Text) + Begriffe. Komponiert als feld:(...)-Gruppen, per Leerzeichen
        // (UND) bzw. " OR " (ODER) verknuepft. Bidirektional mit dem Suchfeld. Anhang bleibt orthogonal.
        (function () {
            var box = document.getElementById('SearchTerm');
            var attachSel = document.getElementById('adv_attach');
            var advRows = document.getElementById('adv_rows');
            var addBtn = document.getElementById('adv_add_row');
            var VALIDFIELDS = { subject: 1, from: 1, to: 1, body: 1 };
            var FIELD_OPTS = [
                { v: '', t: '@Localizer["AdvScopeAll"]' },
                { v: 'subject', t: '@Localizer["AdvBuilderSubject"]' },
                { v: 'from', t: '@Localizer["AdvBuilderFrom"]' },
                { v: 'to', t: '@Localizer["AdvBuilderTo"]' },
                { v: 'body', t: '@Localizer["AdvScopeBody"]' }
            ];
            var CONN_OPTS = [
                { v: 'and', t: '@Localizer["AdvConnAnd"]' },
                { v: 'or', t: '@Localizer["AdvConnOr"]' }
            ];
            var ROW_PLACEHOLDER = 'rechnung -storno "offene posten"';
            var REMOVE_TITLE = '@Localizer["AdvRemoveCondition"]';

            function attachToken() { return attachSel && attachSel.value === 'yes' ? 'has:attachment' : (attachSel && attachSel.value === 'no' ? '-has:attachment' : ''); }
            function stripAttach(q) { return q.replace(/(^|\s)-?has:\S+/gi, ' ').replace(/\s{2,}/g, ' ').trim(); }
            function withAttach(base) { var t = attachToken(); return (base + (t ? ' ' + t : '')).trim(); }
            function mkSelect(cls, opts, val) {
                var sel = document.createElement('select');
                sel.className = 'form-select form-select-sm ' + cls + ' flex-grow-0 w-auto';
                opts.forEach(function (o) {
                    var op = document.createElement('option');
                    op.value = o.v; op.textContent = o.t;
                    if (o.v === val) op.selected = true;
                    sel.appendChild(op);
                });
                return sel;
            }
            function createRow(conn, field, terms) {
                var row = document.createElement('div');
                row.className = 'adv-row input-group input-group-sm mb-1';
                row.appendChild(mkSelect('adv-row-conn', CONN_OPTS, conn || 'and'));
                row.appendChild(mkSelect('adv-row-field', FIELD_OPTS, field || ''));
                var inp = document.createElement('input');
                inp.type = 'text'; inp.className = 'form-control form-control-sm adv-row-terms';
                inp.autocomplete = 'off'; inp.placeholder = ROW_PLACEHOLDER; inp.value = terms || '';
                row.appendChild(inp);
                var rm = document.createElement('button');
                rm.type = 'button'; rm.className = 'btn btn-outline-secondary adv-row-remove';
                rm.title = REMOVE_TITLE; rm.innerHTML = '<i class="bi bi-x-lg"></i>';
                row.appendChild(rm);
                return row;
            }
            // Konnektor der ersten Zeile ausblenden (Platz reservieren -> Felder bleiben ausgerichtet).
            function syncConnectors() {
                if (!advRows) return;
                var rows = advRows.querySelectorAll('.adv-row');
                for (var i = 0; i < rows.length; i++) {
                    var c = rows[i].querySelector('.adv-row-conn');
                    if (c) c.style.visibility = i === 0 ? 'hidden' : 'visible';
                }
            }
            function renderRows(list) {
                if (!advRows) return;
                advRows.innerHTML = '';
                if (!list || !list.length) list = [{ conn: 'and', field: '', terms: '' }];
                list.forEach(function (r) { advRows.appendChild(createRow(r.conn, r.field, r.terms)); });
                syncConnectors();
            }
            function readRows() {
                if (!advRows) return [];
                return Array.prototype.map.call(advRows.querySelectorAll('.adv-row'), function (row) {
                    return {
                        conn: row.querySelector('.adv-row-conn').value,
                        field: row.querySelector('.adv-row-field').value,
                        terms: row.querySelector('.adv-row-terms').value.trim()
                    };
                });
            }
            // Zeilen -> Query: feld:(...) je Zeile, per Leerzeichen (UND) bzw. " OR " (ODER) verknuepft.
            function build() {
                var q = '';
                readRows().forEach(function (r) {
                    var t = r.terms.replace(/[()]/g, '').trim();
                    if (!t) return;
                    var piece = r.field ? r.field + ':(' + t + ')' : t;
                    if (!q) q = piece;
                    else q += (r.conn === 'or' ? ' OR ' : ' ') + piece;
                });
                return q;
            }
            function boxFromBuilder() { if (box) box.value = withAttach(build()); }
            function isOr(t) { return t === '|' || /^(or|oder)$/i.test(t); }
            function isGroup(t) { return /^\w+:\(/.test(t); }
            // Query -> Zeilen: feld:(...)-Gruppen und Top-Level-ODER werden Zeilen(-Konnektoren);
            // ODER zwischen zwei nackten Begriffen bleibt innerhalb einer "Alle Felder"-Zeile.
            function parseIntoRows(query) {
                var q = stripAttach(query).trim();
                var tokens = q.match(/\w+:\([^)]*\)|[-!]?\w+:"[^"]*"|[-!]?\w+:\S+|[-!]?"[^"]*"|\S+/g) || [];
                var rows = [], cur = null, pendingConn = 'and';
                function flush() { if (cur) { rows.push({ conn: cur.conn, field: cur.field, terms: cur.terms.join(' ') }); cur = null; } }
                for (var k = 0; k < tokens.length; k++) {
                    var t = tokens[k];
                    if (isOr(t)) {
                        var next = tokens[k + 1];
                        if (cur && cur.field === '' && next && !isOr(next) && !isGroup(next)) { cur.terms.push('OR'); }
                        else { flush(); pendingConn = 'or'; }
                        continue;
                    }
                    var gm = t.match(/^(\w+):\(([\s\S]*)\)$/);
                    if (gm && VALIDFIELDS[gm[1].toLowerCase()]) {
                        flush();
                        rows.push({ conn: pendingConn, field: gm[1].toLowerCase(), terms: gm[2].trim() });
                        pendingConn = 'and';
                        continue;
                    }
                    if (cur && cur.field === '') { cur.terms.push(t); }
                    else { flush(); cur = { conn: pendingConn, field: '', terms: [t] }; pendingConn = 'and'; }
                }
                flush();
                renderRows(rows);
            }
            function attachFromBox() {
                if (!attachSel || !box) return;
                var q = box.value;
                attachSel.value = /(^|\s)-has:\S+/i.test(q) ? 'no' : (/(^|\s)has:\S+/i.test(q) ? 'yes' : '');
            }

            if (advRows) {
                advRows.addEventListener('change', function (e) {
                    if (e.target.classList.contains('adv-row-field') || e.target.classList.contains('adv-row-terms') || e.target.classList.contains('adv-row-conn')) boxFromBuilder();
                });
                advRows.addEventListener('keydown', function (e) {
                    if (e.key === 'Enter' && e.target.classList.contains('adv-row-terms')) boxFromBuilder();
                });
                advRows.addEventListener('click', function (e) {
                    var b = e.target.closest('.adv-row-remove');
                    if (b) { var row = b.closest('.adv-row'); if (row) row.remove(); if (!advRows.querySelector('.adv-row')) renderRows([]); syncConnectors(); boxFromBuilder(); }
                });
            }
            if (addBtn) addBtn.addEventListener('click', function () {
                var r = createRow('and', '', ''); advRows.appendChild(r); syncConnectors();
                var inp = r.querySelector('.adv-row-terms'); if (inp) inp.focus();
            });
            if (attachSel) attachSel.addEventListener('change', function () {
                if (box) box.value = withAttach(stripAttach(box.value));
            });
            function builderFromBox() { if (box) { parseIntoRows(box.value.trim()); attachFromBox(); } }
            if (box) {
                box.addEventListener('change', builderFromBox);
                box.addEventListener('keydown', function (e) { if (e.key === 'Enter') builderFromBox(); });
            }
            var advCollapse = document.getElementById('advSearchHelp');
            if (advCollapse) advCollapse.addEventListener('show.bs.collapse', builderFromBox);
            var advForm = document.getElementById('searchForm');
            if (advForm) advForm.addEventListener('submit', function () {
                if (box && !box.value.trim()) { var c = withAttach(build()); if (c) box.value = c; }
            });
            if (box && box.value.trim()) parseIntoRows(box.value.trim()); else renderRows([]);
            attachFromBox();
        })();
    });
</script>
}