@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.PstImportJob
@{
    ViewData["Title"] = Localizer["PstImportStatusTitle"];
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@Localizer["PstImportStatusTitle"]</h1>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> @Localizer["BackToAccounts"]
            </a>
            <a asp-controller="Emails" asp-action="Jobs" class="btn btn-outline-info">
                <i class="bi bi-list"></i> @Localizer["AllJobs"]
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">@Localizer["ImportJobInformation"]</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Localizer["JobIDLabel"]</dt>
                <dd class="col-sm-9"><code>@Model.JobId</code></dd>

                <dt class="col-sm-3">@Localizer["FileNameLabel"]</dt>
                <dd class="col-sm-9">@Model.FileName</dd>

                <dt class="col-sm-3">@Localizer["FileSizeLabel"]</dt>
                <dd class="col-sm-9">@FormatFileSize(Model.FileSize)</dd>

                <dt class="col-sm-3">@Localizer["FolderModeLabel"]</dt>
                <dd class="col-sm-9">
                    @if (Model.PreserveFolderStructure)
                    {
                        <span class="badge bg-info">@Localizer["FolderModePreserve"]</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@string.Format(Localizer["FolderModeAllTo"], Model.TargetFolder)</span>
                    }
                </dd>

                <dt class="col-sm-3">@Localizer["StatusLabel"]</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-@(Model.Status == MailArchiver.Models.PstImportJobStatus.Running ? "primary" :
                                           Model.Status == MailArchiver.Models.PstImportJobStatus.Completed ? "success" :
                                           Model.Status == MailArchiver.Models.PstImportJobStatus.CompletedWithErrors ? "warning" :
                                           Model.Status == MailArchiver.Models.PstImportJobStatus.Failed ? "danger" :
                                           Model.Status == MailArchiver.Models.PstImportJobStatus.Cancelled ? "warning" : "secondary") fs-6">
                        @Model.Status
                    </span>
                </dd>

                <dt class="col-sm-3">@Localizer["EmailsLabelStatus"]</dt>
                <dd class="col-sm-9">
                    @if (Model.Status == MailArchiver.Models.PstImportJobStatus.Running)
                    {
                        <span>@Model.ProcessedEmails.ToString("N0") @Localizer["ProcessedSuffix"]</span>
                        @if (Model.TotalEmails > 0)
                        {
                            <span class="text-muted"> (@Localizer["EstimatedSuffix"]: @Model.TotalEmails.ToString("N0"))</span>
                        }
                    }
                    else
                    {
                        <span>@Model.ProcessedEmails.ToString("N0") @Localizer["EmailsProcessedSuffix"]</span>
                    }
                </dd>

                @if (Model.Status == MailArchiver.Models.PstImportJobStatus.Running ||
                     Model.Status == MailArchiver.Models.PstImportJobStatus.Completed ||
                     Model.Status == MailArchiver.Models.PstImportJobStatus.CompletedWithErrors)
                {
                    <dt class="col-sm-3">@Localizer["ResultsLabel"]</dt>
                    <dd class="col-sm-9">
                        <div class="row g-2">
                            <div class="col-auto">
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle me-1"></i>
                                    @Localizer["SuccessLabel"] @Model.SuccessCount.ToString("N0")
                                </span>
                            </div>
                            <div class="col-auto">
                                <span class="badge bg-danger">
                                    <i class="bi bi-x-circle me-1"></i>
                                    @Localizer["FailedLabel"] @Model.FailedCount.ToString("N0")
                                </span>
                            </div>
                            @if (Model.SkippedAlreadyExistsCount > 0)
                            {
                                <div class="col-auto">
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-skip-forward me-1"></i>
                                        @Localizer["DuplicatesLabel"] @Model.SkippedAlreadyExistsCount.ToString("N0")
                                    </span>
                                </div>
                            }
                        </div>
                    </dd>
                }

                @if (Model.Status == MailArchiver.Models.PstImportJobStatus.Running && !string.IsNullOrEmpty(Model.CurrentFolder))
                {
                    <dt class="col-sm-3">@Localizer["CurrentFolderLabel"]</dt>
                    <dd class="col-sm-9">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-folder me-1"></i>@Model.CurrentFolder
                        </span>
                    </dd>
                }

                @if (Model.Status == MailArchiver.Models.PstImportJobStatus.Running && !string.IsNullOrEmpty(Model.CurrentEmailSubject))
                {
                    <dt class="col-sm-3">@Localizer["CurrentEmailLabel"]</dt>
                    <dd class="col-sm-9">
                        <small class="text-muted">
                            @(Model.CurrentEmailSubject.Length > 80 ? Model.CurrentEmailSubject[..80] + "…" : Model.CurrentEmailSubject)
                        </small>
                    </dd>
                }

                <dt class="col-sm-3">@Localizer["CreatedLabel"]</dt>
                <dd class="col-sm-9">
                    <span class="utc-timestamp" data-utc-time="@Model.Created.ToString("yyyy-MM-ddTHH:mm:ss")">
                        @Model.Created.ToString("g")
                    </span>
                </dd>

                @if (Model.Started.HasValue)
                {
                    <dt class="col-sm-3">@Localizer["StartedLabel"]</dt>
                    <dd class="col-sm-9">
                        <span class="utc-timestamp" data-utc-time="@Model.Started.Value.ToString("yyyy-MM-ddTHH:mm:ss")">
                            @Model.Started.Value.ToString("g")
                        </span>
                    </dd>
                }

                @if (Model.Completed.HasValue)
                {
                    <dt class="col-sm-3">@Localizer["CompletedLabel"]</dt>
                    <dd class="col-sm-9">
                        <span class="utc-timestamp" data-utc-time="@Model.Completed.Value.ToString("yyyy-MM-ddTHH:mm:ss")">
                            @Model.Completed.Value.ToString("g")
                        </span>
                    </dd>
                    @if (Model.Started.HasValue)
                    {
                        var duration = Model.Completed.Value - Model.Started.Value;
                        <dt class="col-sm-3">@Localizer["DurationLabel"]</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-info">@duration.ToString(@"hh\:mm\:ss")</span>
                        </dd>
                    }
                }

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <dt class="col-sm-3">@(Model.Status == MailArchiver.Models.PstImportJobStatus.CompletedWithErrors ? Localizer["DetailsLabel"] : Localizer["ErrorLabel"])</dt>
                    <dd class="col-sm-9">
                        <div class="alert @(Model.Status == MailArchiver.Models.PstImportJobStatus.CompletedWithErrors ? "alert-warning" : "alert-danger")">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @Model.ErrorMessage
                        </div>
                    </dd>
                }
            </dl>

            @if (Model.Status == MailArchiver.Models.PstImportJobStatus.Running || Model.Status == MailArchiver.Models.PstImportJobStatus.Queued)
            {
                <div class="mt-4 pt-3 border-top">
                    <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#cancelImportModal">
                        <i class="bi bi-stop-circle"></i> @Localizer["CancelImport"]
                    </button>
                </div>
            }

            @if (Model.Status == MailArchiver.Models.PstImportJobStatus.Completed)
            {
                <div class="mt-4 pt-3 border-top">
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <strong>@Localizer["ImportCompletedTitle"]</strong>
                        @string.Format(Localizer["ImportCompletedSummary"], Model.SuccessCount.ToString("N0"), Model.FailedCount.ToString("N0"))
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-controller="Emails" asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>@Localizer["SearchImportedEmails"]
                        </a>
                        <a asp-action="ImportPst" class="btn btn-outline-success">
                            <i class="bi bi-upload me-1"></i>@Localizer["ImportAnotherFile"]
                        </a>
                    </div>
                </div>
            }

            @if (Model.Status == MailArchiver.Models.PstImportJobStatus.CompletedWithErrors)
            {
                <div class="mt-4 pt-3 border-top">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>@Localizer["ImportCompletedWithErrorsTitle"]</strong>
                        @Localizer["ImportCompletedWithErrorsDescription"]
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-controller="Emails" asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-search me-1"></i>@Localizer["SearchImportedEmails"]
                        </a>
                        <a asp-action="ImportPst" class="btn btn-outline-success">
                            <i class="bi bi-upload me-1"></i>@Localizer["ImportAnotherFile"]
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    string FormatFileSize(long bytes)
    {
        string[] suffixes = { "B", "KB", "MB", "GB", "TB" };
        int counter = 0;
        decimal number = bytes;
        while (Math.Round(number / 1024) >= 1) { number /= 1024; counter++; }
        return $"{number:n1} {suffixes[counter]}";
    }
}

@if (Model.Status == MailArchiver.Models.PstImportJobStatus.Running || Model.Status == MailArchiver.Models.PstImportJobStatus.Queued)
{
    @section Scripts {
        <script>
            setTimeout(function () { location.reload(); }, 5000);
            let countdown = 5;
            const pstImportStatusTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PstImportStatusTitle"].Value));
            const interval = setInterval(function () {
                countdown--;
                document.title = `(${countdown}s) ${pstImportStatusTitle} - @Model.FileName`;
                if (countdown <= 0) clearInterval(interval);
            }, 1000);
        </script>
    }
}

<div class="modal fade" id="cancelImportModal" tabindex="-1" aria-labelledby="cancelImportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cancelImportModalLabel">@Localizer["CancelImport"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">@Localizer["CancelImportConfirm"]</div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Close"]</button>
                <form asp-action="CancelPstImport" method="post" style="display: inline;">
                    <input type="hidden" name="jobId" value="@Model.JobId" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="btn btn-warning">@Localizer["CancelImport"]</button>
                </form>
            </div>
        </div>
    </div>
</div>
