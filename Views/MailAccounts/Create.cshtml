@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.CreateMailAccountViewModel
@{
    ViewData["Title"] = @Localizer["CreateNewEmailAccount"];
    var visualProvider = Model.Provider == ProviderType.M365 && Model.ImportEntireTenant ? "M365Tenant"
        : Model.Provider == ProviderType.M365 ? "M365Single"
        : Model.Provider.ToString();
    var imapSettingsDisplay = Model.Provider == ProviderType.IMAP ? "block" : "none";
    var microsoft365SettingsDisplay = Model.Provider == ProviderType.M365 ? "block" : "none";
    var emailDeletionSettingsDisplay = Model.Provider == ProviderType.IMPORT ? "none" : "block";
    var tenantImportControlsDisplay = Model.Provider == ProviderType.M365 && Model.ImportEntireTenant ? "block" : "none";
    var tenantImportSettingsDisplay = Model.Provider == ProviderType.M365 && Model.ImportEntireTenant ? "block" : "none";
}

<div class="container">
    <h1>@Localizer["CreateNewEmailAccount"]</h1>
    
    <div class="card">
        <div class="card-body">
            <form asp-action="Create" id="createMailAccountForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                
                <div class="mb-3" id="nameField">
                    <label asp-for="Name" class="form-label">@Localizer["AccountName"]</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                
                <div class="mb-3" id="emailAddressField">
                    <label asp-for="EmailAddress" class="form-label">@Localizer["EmailAddress"]</label>
                    <input asp-for="EmailAddress" class="form-control" type="email" />
                    <span asp-validation-for="EmailAddress" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label for="ProviderDisplay" class="form-label">@Localizer["Provider"]</label>
                    <select id="ProviderDisplay" class="form-select">
                        <option value="IMAP" selected="@(visualProvider == "IMAP")">IMAP</option>
                        <option value="M365Single" selected="@(visualProvider == "M365Single")">@Localizer["ProviderM365Single"]</option>
                        <option value="M365Tenant" selected="@(visualProvider == "M365Tenant")">@Localizer["ProviderM365Tenant"]</option>
                        <option value="IMPORT" selected="@(visualProvider == "IMPORT")">Import Only</option>
                    </select>
                    <input type="hidden" asp-for="Provider" />
                    <input type="hidden" asp-for="ImportEntireTenant" />
                    <span asp-validation-for="Provider" class="text-danger"></span>
                </div>
                
                <div id="imapSettings" style="display: @imapSettingsDisplay;">
                    <h4 class="mt-4">IMAP Settings</h4>
                    
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="ImapServer" class="form-label">@Localizer["IMAPServer"]</label>
                            <input asp-for="ImapServer" class="form-control" />
                            <span asp-validation-for="ImapServer" class="text-danger"></span>
                        </div>
                        
                        <div class="col-md-4 mb-3">
                            <label asp-for="ImapPort" class="form-label">@Localizer["IMAPPort"]</label>
                            <input asp-for="ImapPort" class="form-control" />
                            <span asp-validation-for="ImapPort" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <h4 class="mt-4">@Localizer["Authentication"]</h4>
                    
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">@Localizer["Username"]</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                        <input asp-for="Password" class="form-control" type="password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3 form-check">
                        <input asp-for="UseSSL" class="form-check-input" />
                        <label asp-for="UseSSL" class="form-check-label">@Localizer["UseSSL"]</label>
                    </div>
                </div>
                
                <div id="microsoft365Settings" style="display: @microsoft365SettingsDisplay;">
                    <h4 class="mt-4">@Localizer["Microsoft365Settings"]</h4>
                    
                    <div id="existingAccountSuggestion" class="m365-suggestion-box" style="display: none;">
                        <h6 class="alert-heading"><i class="bi bi-info-circle"></i> @Localizer["ExistingM365AccountsFound"]</h6>
                        <p class="mb-2">@Localizer["UseExistingCredentialsPrompt"]</p>
                        <select id="existingAccountSelect" class="form-select mb-2">
                            <option value="">@Localizer["SelectAccount"]</option>
                        </select>
                        <button type="button" id="copyCredentialsBtn" class="btn btn-sm btn-primary">
                            <i class="bi bi-copy"></i> @Localizer["CopyCredentials"]
                        </button>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ClientId" class="form-label">@Localizer["ClientId"]</label>
                        <input asp-for="ClientId" class="form-control" />
                        <span asp-validation-for="ClientId" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ClientSecret" class="form-label">@Localizer["ClientSecret"]</label>
                        <input asp-for="ClientSecret" class="form-control" type="password" />
                        <span asp-validation-for="ClientSecret" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="TenantId" class="form-label">@Localizer["TenantId"]</label>
                        <input asp-for="TenantId" class="form-control" />
                        <span asp-validation-for="TenantId" class="text-danger"></span>
                    </div>

                    <div id="tenantImportControls" style="display: @tenantImportControlsDisplay;">
                        <div id="tenantImportSettings" style="display: @tenantImportSettingsDisplay;">
                            <div class="mb-3 form-check">
                                <input asp-for="SkipDisabledMailboxes" class="form-check-input" />
                                <label asp-for="SkipDisabledMailboxes" class="form-check-label">@Localizer["SkipDisabledMailboxes"]</label>
                            </div>

                            <div class="mb-3 form-check">
                                <input asp-for="ImportAllTenantMailboxes" class="form-check-input" />
                                <label asp-for="ImportAllTenantMailboxes" class="form-check-label">@Localizer["ImportAllListedMailboxes"]</label>
                                <div class="form-text">@Localizer["ImportAllListedMailboxesHelp"]</div>
                            </div>

                            <div class="card border-light bg-light mb-3">
                                <div class="card-body">
                                    <h6 class="card-title">@Localizer["TenantMailboxes"]</h6>
                                    <p class="card-text small text-muted mb-3">@Localizer["LoadMailboxesHelp"]</p>
                                    <button type="button" id="loadTenantMailboxesBtn" class="btn btn-outline-primary w-100">
                                        <i class="bi bi-arrow-repeat"></i> @Localizer["LoadMailboxes"]
                                    </button>
                                    <div id="tenantMailboxStatus" class="mt-2 small text-center" style="display: none;"></div>
                                </div>
                            </div>

                            <div id="tenantMailboxSelection" class="border rounded p-3 mb-3" style="display: none; max-height: 320px; overflow-y: auto;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <strong>@Localizer["TenantMailboxes"]</strong>
                                    <div class="btn-group btn-group-sm">
                                        <button type="button" id="selectAllTenantMailboxesBtn" class="btn btn-outline-secondary">@Localizer["SelectAll"]</button>
                                        <button type="button" id="clearTenantMailboxesBtn" class="btn btn-outline-secondary">@Localizer["ClearSelection"]</button>
                                    </div>
                                </div>
                                <div id="tenantMailboxList"></div>
                                <span asp-validation-for="SelectedM365Mailboxes" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="mb-3 form-check" id="accountEnabledField">
                    <input asp-for="IsEnabled" class="form-check-input" />
                    <label asp-for="IsEnabled" class="form-check-label">@Localizer["AccountEnabled"]</label>
                    <div class="form-text">@Localizer["DisabledAccountsNotSynced"]</div>
                </div>
                
                <div id="emailDeletionSettings" style="display: @emailDeletionSettingsDisplay;">
                    <h4 class="mt-4">@Localizer["EmailDeletion"]</h4>
                    <div class="mb-3">
                        <label asp-for="DeleteAfterDays" class="form-label">@Localizer["DeleteAfterDays"]</label>
                        <input asp-for="DeleteAfterDays" class="form-control" type="number" min="1" placeholder="@Localizer["LeaveEmptyToDisableAutomaticDeletion"]" />
                        <div class="form-text">@Localizer["AutoDeleteText"]</div>
                        <span asp-validation-for="DeleteAfterDays" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LocalRetentionDays" class="form-label">@Localizer["LocalRetentionDays"]</label>
                        <input asp-for="LocalRetentionDays" class="form-control" type="number" min="1" placeholder="@Localizer["LeaveEmptyToDisableAutomaticDeletion"]" />
                        <div class="form-text">@Localizer["LocalRetentionInfo"]</div>
                        <span asp-validation-for="LocalRetentionDays" class="text-danger"></span>
                    </div>
                </div>
                
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["BackToList"]</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const createForm = document.getElementById('createMailAccountForm');
            const providerDisplaySelect = document.getElementById('ProviderDisplay');
            const providerInput = document.getElementById('Provider');
            const importEntireTenantInput = document.getElementById('ImportEntireTenant');
            const imapSettings = document.getElementById('imapSettings');
            const microsoft365Settings = document.getElementById('microsoft365Settings');
            const emailDeletionSettings = document.getElementById('emailDeletionSettings');
            const nameField = document.getElementById('nameField');
            const emailAddressField = document.getElementById('emailAddressField');
            const accountEnabledField = document.getElementById('accountEnabledField');
            const isEnabledInput = document.getElementById('IsEnabled');
            const emailAddressInput = document.getElementById('EmailAddress');
            const existingAccountSuggestion = document.getElementById('existingAccountSuggestion');
            const existingAccountSelect = document.getElementById('existingAccountSelect');
            const copyCredentialsBtn = document.getElementById('copyCredentialsBtn');
            const clientIdInput = document.getElementById('ClientId');
            const clientSecretInput = document.getElementById('ClientSecret');
            const tenantIdInput = document.getElementById('TenantId');
            const importAllTenantMailboxesInput = document.getElementById('ImportAllTenantMailboxes');
            const skipDisabledMailboxesInput = document.getElementById('SkipDisabledMailboxes');
            const tenantImportControls = document.getElementById('tenantImportControls');
            const tenantImportSettings = document.getElementById('tenantImportSettings');
            const loadTenantMailboxesBtn = document.getElementById('loadTenantMailboxesBtn');
            const tenantMailboxStatus = document.getElementById('tenantMailboxStatus');
            const tenantMailboxSelection = document.getElementById('tenantMailboxSelection');
            const tenantMailboxList = document.getElementById('tenantMailboxList');
            const selectAllTenantMailboxesBtn = document.getElementById('selectAllTenantMailboxesBtn');
            const clearTenantMailboxesBtn = document.getElementById('clearTenantMailboxesBtn');
            
            let existingAccounts = [];
            
            function setSectionEnabled(section, enabled) {
                section.querySelectorAll('input, select, textarea, button').forEach(element => {
                    element.disabled = !enabled;
                });
            }

            function syncProviderFields() {
                const visualValue = providerDisplaySelect.value;
                if (visualValue === 'M365Single') {
                    providerInput.value = '@ProviderType.M365';
                    importEntireTenantInput.value = 'false';
                } else if (visualValue === 'M365Tenant') {
                    providerInput.value = '@ProviderType.M365';
                    importEntireTenantInput.value = 'true';
                } else {
                    providerInput.value = visualValue;
                    importEntireTenantInput.value = 'false';
                }
            }

            function isM365Selected() {
                return providerDisplaySelect.value === 'M365Single' || providerDisplaySelect.value === 'M365Tenant';
            }

            function isTenantImportSelected() {
                return providerDisplaySelect.value === 'M365Tenant';
            }

            function toggleTenantImportFields() {
                const isM365 = isM365Selected();
                const isTenantImport = isTenantImportSelected();
                emailAddressField.style.display = isTenantImport ? 'none' : 'block';
                nameField.style.display = 'block';
                tenantImportControls.style.display = isTenantImport ? 'block' : 'none';
                tenantImportSettings.style.display = isTenantImport ? 'block' : 'none';
                tenantMailboxSelection.style.display = isTenantImport ? tenantMailboxSelection.style.display : 'none';
                accountEnabledField.style.display = isTenantImport ? 'none' : 'block';

                if (isTenantImport && isEnabledInput) {
                    isEnabledInput.checked = true;
                }
            }

            function toggleSettings(skipSuggestionCheck) {
                const visualValue = providerDisplaySelect.value;
                const isImport = visualValue === 'IMPORT';
                const isM365 = isM365Selected();
                const isImap = !isImport && !isM365;

                imapSettings.style.display = isImap ? 'block' : 'none';
                microsoft365Settings.style.display = isM365 ? 'block' : 'none';
                emailDeletionSettings.style.display = isImport ? 'none' : 'block';
                setSectionEnabled(imapSettings, isImap);
                setSectionEnabled(microsoft365Settings, isM365);

                if (!isM365) {
                    existingAccountSuggestion.style.display = 'none';
                }

                toggleTenantImportFields();

                if (isM365 && !skipSuggestionCheck) {
                    checkForExistingAccounts();
                }
            }
            
            let lastCheckedEmail = '';
            let lastCheckedDomain = '';
            
            function checkForExistingAccounts() {
                const emailAddress = emailAddressInput.value.trim();

                // Need at least an at-symbol to have a domain
                if (!emailAddress || !emailAddress.includes(String.fromCharCode(64))) {
                    // Only hide if we haven't found accounts yet
                    if (existingAccounts.length === 0) {
                        existingAccountSuggestion.style.display = 'none';
                    }
                    return;
                }
                
                // Extract domain from email
                const domain = emailAddress.split(String.fromCharCode(64))[1];
                if (!domain) {
                    return;
                }
                
                // If domain hasn't changed and we have accounts, don't check again
                if (domain === lastCheckedDomain && existingAccounts.length > 0) {
                    return;
                }
                
                // If domain changed, we need to check again but don't reset yet
                const domainChanged = (domain !== lastCheckedDomain);
                
                lastCheckedEmail = emailAddress;
                lastCheckedDomain = domain;
                
                fetch('@Url.Action("CheckM365AccountsForDomain", "MailAccounts")?emailAddress=' + encodeURIComponent(emailAddress))
                    .then(response => response.json())
                    .then(data => {
                        if (data.exists && data.accounts && data.accounts.length > 0) {
                            existingAccounts = data.accounts;
                            
                            // Clear and populate select
                            existingAccountSelect.innerHTML = '<option value="">@Localizer["SelectAccount"]</option>';
                            data.accounts.forEach(account => {
                                const option = document.createElement('option');
                                option.value = account.id;
                                option.textContent = account.name + ' (' + account.emailAddress + ')';
                                existingAccountSelect.appendChild(option);
                            });
                            
                            // Automatically switch to M365 single mailbox when coming from a non-M365 provider
                            if (!isM365Selected()) {
                                providerDisplaySelect.value = 'M365Single';
                                syncProviderFields();
                                toggleSettings(true);
                            }

                            existingAccountSuggestion.style.display = 'block';
                            microsoft365Settings.style.display = 'block';
                        } else {
                            existingAccounts = [];
                            lastCheckedEmail = '';
                            existingAccountSuggestion.style.display = 'none';
                        }
                    })
                    .catch(error => {
                        console.error('Error checking for existing accounts:', error);
                        existingAccounts = [];
                        lastCheckedEmail = '';
                        existingAccountSuggestion.style.display = 'none';
                    });
            }
            
            function htmlDecode(input) {
                const doc = new DOMParser().parseFromString(input, "text/html");
                return doc.documentElement.textContent;
            }

            function copyCredentials() {
                const selectedAccountId = existingAccountSelect.value;
                if (!selectedAccountId) {
                    alert(htmlDecode('@Localizer["PleaseSelectAccount"]'));
                    return;
                }
                
                fetch('@Url.Action("GetM365Credentials", "MailAccounts")?accountId=' + selectedAccountId)
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            // Fill in the credentials
                            clientIdInput.value = data.clientId || '';
                            clientSecretInput.value = data.clientSecret || '';
                            tenantIdInput.value = data.tenantId || '';
                            
                            // Hide suggestion box after copying
                            existingAccountSuggestion.style.display = 'none';
                            
                            // Show success message
                            const successMsg = document.createElement('div');
                            successMsg.className = 'alert alert-success alert-dismissible fade show mt-2';
                            successMsg.innerHTML = '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>@Localizer["CredentialsCopied"]';
                            microsoft365Settings.insertBefore(successMsg, microsoft365Settings.firstChild.nextSibling);
                            
                            setTimeout(() => {
                                successMsg.remove();
                            }, 3000);
                        } else {
                            alert(htmlDecode('@Localizer["ErrorCopyingCredentials"]: ' + (data.message || 'Unknown error')));
                        }
                    })
                    .catch(error => {
                        console.error('Error copying credentials:', error);
                        alert(htmlDecode('@Localizer["ErrorCopyingCredentials"]'));
                    });
            }

            function renderTenantMailboxes(mailboxes) {
                tenantMailboxList.innerHTML = '';

                if (!mailboxes || mailboxes.length === 0) {
                    tenantMailboxList.innerHTML = '<div class="text-muted">@Localizer["NoMailboxesFound"]</div>';
                    tenantMailboxSelection.style.display = 'block';
                    return;
                }

                mailboxes.forEach((mailbox, index) => {
                    const wrapper = document.createElement('div');
                    wrapper.className = 'form-check mb-2';

                    const checkbox = document.createElement('input');
                    checkbox.type = 'checkbox';
                    checkbox.className = 'form-check-input';
                    checkbox.id = 'tenantMailbox_' + index;
                    checkbox.name = 'SelectedM365Mailboxes';
                    checkbox.value = mailbox.emailAddress;
                    checkbox.checked = importAllTenantMailboxesInput.checked && !mailbox.alreadyExists;
                    checkbox.disabled = importAllTenantMailboxesInput.checked || mailbox.alreadyExists;
                    if (mailbox.alreadyExists) {
                        checkbox.dataset.existingAccount = 'true';
                    }

                    const label = document.createElement('label');
                    label.className = 'form-check-label';
                    label.htmlFor = checkbox.id;
                    label.textContent = mailbox.displayName + ' <' + mailbox.emailAddress + '>';

                    if (mailbox.isDisabled) {
                        const disabledBadge = document.createElement('span');
                        disabledBadge.className = 'badge bg-warning text-dark ms-2';
                        disabledBadge.textContent = '@Localizer["DisabledLowercase"]';
                        label.appendChild(disabledBadge);
                    }

                    if (mailbox.alreadyExists) {
                        const existingBadge = document.createElement('span');
                        existingBadge.className = 'badge bg-secondary ms-2';
                        existingBadge.textContent = '@Localizer["AlreadyExistsLowercase"]';
                        label.appendChild(existingBadge);
                    }

                    wrapper.appendChild(checkbox);
                    wrapper.appendChild(label);
                    tenantMailboxList.appendChild(wrapper);
                });

                tenantMailboxSelection.style.display = 'block';
            }

            function loadTenantMailboxes() {
                const tokenInput = createForm.querySelector('input[name="__RequestVerificationToken"]');
                const formData = new FormData();
                formData.append('__RequestVerificationToken', tokenInput ? tokenInput.value : '');
                formData.append('clientId', clientIdInput.value);
                formData.append('clientSecret', clientSecretInput.value);
                formData.append('tenantId', tenantIdInput.value);
                formData.append('skipDisabledMailboxes', skipDisabledMailboxesInput.checked);

                tenantMailboxStatus.style.display = 'block';
                tenantMailboxStatus.textContent = '@Localizer["LoadingMailboxes"]';
                tenantMailboxStatus.className = 'mt-2 small text-center text-muted';
                loadTenantMailboxesBtn.disabled = true;

                fetch('@Url.Action("ListM365TenantMailboxes", "MailAccounts")', {
                    method: 'POST',
                    body: formData
                })
                    .then(response => response.json())
                    .then(data => {
                        if (!data.success) {
                            tenantMailboxStatus.textContent = data.message || '@Localizer["MailboxesCouldNotBeLoaded"]';
                            tenantMailboxStatus.className = 'mt-2 small text-center text-danger';
                            return;
                        }

                        renderTenantMailboxes(data.mailboxes);
                        tenantMailboxStatus.textContent = '@Localizer["MailboxesFound"]'.replace('{0}', (data.mailboxes || []).length);
                        tenantMailboxStatus.className = 'mt-2 small text-center text-muted';
                    })
                    .catch(error => {
                        console.error('Error loading tenant mailboxes:', error);
                        tenantMailboxStatus.textContent = '@Localizer["MailboxesCouldNotBeLoaded"]';
                        tenantMailboxStatus.className = 'mt-2 small text-center text-danger';
                    })
                    .finally(() => {
                        loadTenantMailboxesBtn.disabled = false;
                    });
            }

            // Initial check
            syncProviderFields();
            toggleSettings();
            
            // Add event listeners
            providerDisplaySelect.addEventListener('change', function() {
                syncProviderFields();
                toggleSettings();
            });

            importAllTenantMailboxesInput.addEventListener('change', function() {
                tenantMailboxList.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                    const alreadyExists = checkbox.dataset.existingAccount === 'true';
                    checkbox.disabled = alreadyExists || this.checked;
                    if (this.checked && !alreadyExists) {
                        checkbox.checked = true;
                    }
                });
            });

            skipDisabledMailboxesInput.addEventListener('change', function() {
                if (tenantMailboxSelection.style.display !== 'none') {
                    loadTenantMailboxes();
                }
            });

            loadTenantMailboxesBtn.addEventListener('click', loadTenantMailboxes);
            selectAllTenantMailboxesBtn.addEventListener('click', function() {
                importAllTenantMailboxesInput.checked = false;
                tenantMailboxList.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                    const alreadyExists = checkbox.dataset.existingAccount === 'true';
                    checkbox.disabled = alreadyExists;
                    checkbox.checked = !alreadyExists;
                });
            });
            clearTenantMailboxesBtn.addEventListener('click', function() {
                importAllTenantMailboxesInput.checked = false;
                tenantMailboxList.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
                    const alreadyExists = checkbox.dataset.existingAccount === 'true';
                    checkbox.disabled = alreadyExists;
                    checkbox.checked = false;
                });
            });
            
            // Check for existing accounts while typing email address
            emailAddressInput.addEventListener('input', function() {
                checkForExistingAccounts();
            });
            
            copyCredentialsBtn.addEventListener('click', copyCredentials);
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
