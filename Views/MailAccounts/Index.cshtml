@using MailArchiver.Models.ViewModels
@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@inject MailArchiver.Services.IAuthenticationService AuthService
@model IEnumerable<MailArchiver.Models.ViewModels.MailAccountViewModel>
@{
    ViewData["Title"] = @Localizer["EmailAccounts"];
    var isAdmin = AuthService.IsCurrentUserAdmin(Context);
    var isSelfManager = AuthService.IsCurrentUserSelfManager(Context);
    var canExport = isAdmin || isSelfManager;
    ViewBag.IsAdmin = isAdmin;
    ViewBag.CanExport = canExport;
    var pageSize = 50;
    var totalPages = (int)Math.Ceiling(Model.Count() / (double)pageSize);
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="h3">@Localizer["EmailAccounts"]</h1>
        <div class="d-flex gap-2">
            <div class="dropdown">
                <button class="btn btn-outline-success btn-sm dropdown-toggle" type="button" id="importDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-upload"></i>
                    <span class="d-none d-sm-inline">@Localizer["Import"]</span>
                </button>
                <ul class="dropdown-menu" aria-labelledby="importDropdown">
                    <li><a class="dropdown-item" asp-action="ImportMBox"><i class="bi bi-file-earmark-text me-2"></i>@Localizer["ImportMBox"]</a></li>
                    <li><a class="dropdown-item" asp-action="ImportEml"><i class="bi bi-file-earmark-zip me-2"></i>@Localizer["ImportEml"]</a></li>
                </ul>
            </div>
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i>
                <span class="d-none d-sm-inline">@Localizer["AddAccount"]</span>
            </a>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header bg-light">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2">
                <div class="d-flex align-items-center gap-2 flex-grow-1">
                    <div class="input-group input-group-sm" style="max-width: 300px;">
                        <span class="input-group-text"><i class="bi bi-search" aria-hidden="true"></i></span>
                        <input type="search" id="accountSearch" class="form-control"
                               placeholder="@Localizer["SearchAccounts"]" aria-label="@Localizer["SearchAccounts"]" autocomplete="off" />
                    </div>
                    <span class="small text-nowrap"><strong id="accountTotal">@Model.Count()</strong> @Localizer["AccountsFound", ""]</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="small" id="accountPageInfo" data-template="@Localizer["PageOf", "{PAGE}", "{TOTAL}"]">@Localizer["PageOf", 1, totalPages]</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card d-none d-lg-block card-dropdown-overflow">
        <div class="card-body">
            <div class="table-responsive table-responsive-dropdown">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>@Localizer["Name"]</th>
                            <th>@Localizer["EmailAddress"]</th>
                            <th>@Localizer["Provider"]</th>
                            <th>@Localizer["Sync"]</th>
                            <th>@Localizer["LastSync"]</th>
                            <th>@Localizer["AutoDelete"]</th>
                            <th class="text-center">@Localizer["Actions"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="account-row @(!item.IsEnabled ? "table-secondary" : "")" data-search="@($"{item.Name} {item.EmailAddress} {item.Username}")">
                                <td>@item.Name</td>
                                <td>@item.EmailAddress</td>
                                <td>
                                    @switch (item.Provider)
                                    {
                                        case ProviderType.IMAP:
                                            <span class="badge bg-primary">IMAP</span>
                                            break;
                                        case ProviderType.M365:
                                            <span class="badge bg-success">Microsoft 365</span>
                                            break;
                                        case ProviderType.IMPORT:
                                            <span class="badge bg-secondary">Import Only</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <form asp-action="ToggleEnabled" asp-route-id="@item.Id" method="post" class="d-inline-flex align-items-center">
                                        @Html.AntiForgeryToken()
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input" type="checkbox" role="switch"
                                                   id="enableSwitch_@item.Id"
                                                   checked="@item.IsEnabled"
                                                   onchange="this.form.submit()"
                                                   aria-label="@Localizer["AccountEnabled"]" />
                                            <label class="visually-hidden" for="enableSwitch_@item.Id">@Localizer["AccountEnabled"]</label>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    @if (item.LastSync.HasValue)
                                    {
                                        <span class="utc-timestamp"
                                            data-utc-time="@item.LastSync.Value.ToString("yyyy-MM-ddTHH:mm:ss")">
                                            @item.LastSync.Value.ToString("g")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Localizer["NotSynced"]</span>
                                    }
</td>
                                <td>
                                    @if (item.DeleteAfterDays.HasValue)
                                    {
                                        <span class="badge bg-warning">@item.DeleteAfterDays.Value days</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">@Localizer["Disabled"]</span>
                                    }
                                </td>
                                <td>
                                    @{ await Html.RenderPartialAsync("_AccountActionsMenu", item); }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
</div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            @foreach (var item in Model)
            {
                <text>
                // Handle delete account confirmation for item @item.Id
                document.getElementById('deleteAccountModal-@item.Id-Confirm').addEventListener('click', function() {
                    window.location.href = '@Url.Action("Delete", "MailAccounts", new { id = item.Id })';
                });
                </text>
            }
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var pageSize = 50;
            var currentPage = 1;
            var prevText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Previous"].Value));
            var nextText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Next"].Value));
            var pageInfo = document.getElementById('accountPageInfo');
            var pageOfTemplate = pageInfo ? pageInfo.getAttribute('data-template') : '';
            var noMatchHint = document.getElementById('noAccountMatchHint');
            var searchInput = document.getElementById('accountSearch');

            var desktopRows = Array.from(document.querySelectorAll('.account-row'));
            var mobileRows = Array.from(document.querySelectorAll('.account-card'));
            var allRows = desktopRows.map(function(dr, i) {
                return { desktop: dr, mobile: mobileRows[i], search: (dr.getAttribute('data-search') || '').toLowerCase() };
            });
            var filteredRows = allRows;

            function totalPages() { return Math.max(1, Math.ceil(filteredRows.length / pageSize)); }

            function renderPage() {
                var start = (currentPage - 1) * pageSize;
                var end = start + pageSize;
                allRows.forEach(function(row) {
                    row.desktop.style.display = 'none';
                    row.mobile.style.display = 'none';
                });
                filteredRows.forEach(function(row, idx) {
                    if (idx >= start && idx < end) {
                        row.desktop.style.display = '';
                        row.mobile.style.display = '';
                    }
                });
            }

            function renderPagination() {
                var ul = document.getElementById('accountPagination');
                var card = document.getElementById('accountPaginationCard');
                var pages = totalPages();
                if (pages <= 1) {
                    card.style.display = 'none';
                    ul.innerHTML = '';
                    return;
                }
                card.style.display = '';
                var html = '';
                if (currentPage > 1) {
                    html += '<li class="page-item"><a class="page-link" href="#" data-page="' + (currentPage - 1) + '">' + prevText + '</a></li>';
                }
                var startPage = Math.max(1, currentPage - 1);
                var endPage = Math.min(pages, currentPage + 1);
                for (var i = startPage; i <= endPage; i++) {
                    html += '<li class="page-item ' + (i === currentPage ? 'active' : '') + '"><a class="page-link" href="#" data-page="' + i + '">' + i + '</a></li>';
                }
                if (currentPage < pages) {
                    html += '<li class="page-item"><a class="page-link" href="#" data-page="' + (currentPage + 1) + '">' + nextText + '</a></li>';
                }
                ul.innerHTML = html;
            }

            function updateSummary() {
                var totalEl = document.getElementById('accountTotal');
                if (totalEl) { totalEl.textContent = filteredRows.length; }
                if (pageInfo && pageOfTemplate) {
                    pageInfo.textContent = pageOfTemplate.replace('{PAGE}', currentPage).replace('{TOTAL}', totalPages());
                }
            }

            function updateNoMatchHint() {
                if (noMatchHint) {
                    noMatchHint.style.display = (filteredRows.length === 0 && allRows.length > 0) ? '' : 'none';
                }
            }

            function applyFilter() {
                var term = (searchInput.value || '').trim().toLowerCase();
                if (!term) {
                    filteredRows = allRows;
                } else {
                    filteredRows = allRows.filter(function(row) {
                        return row.search.indexOf(term) !== -1;
                    });
                }
                currentPage = 1;
                renderPage();
                renderPagination();
                updateSummary();
                updateNoMatchHint();
            }

            var pendingFrame = null;
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    if (pendingFrame) { cancelAnimationFrame(pendingFrame); }
                    pendingFrame = requestAnimationFrame(applyFilter);
                });
            }

            var paginationUl = document.getElementById('accountPagination');
            if (paginationUl) {
                paginationUl.addEventListener('click', function(e) {
                    var link = e.target.closest('.page-link');
                    if (!link) { return; }
                    e.preventDefault();
                    var page = parseInt(link.getAttribute('data-page'), 10);
                    if (isNaN(page) || page < 1 || page > totalPages()) { return; }
                    currentPage = page;
                    renderPage();
                    renderPagination();
                    updateSummary();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            }
        });
    </script>

    @foreach (var item in Model)
    {
        var deleteAccountModal = new ModalViewModel
        {
            Id = "deleteAccountModal-" + item.Id,
            Title = Localizer["DeleteEmailAccountTitle"].ToString(),
            Message = string.Format(Localizer["DeleteAccountConfirm"].ToString(), item.EmailAddress),
            IncludeList = true,
            ListTitle1 = Localizer["WhatWillBeDeleted"].ToString(),
            ListItems1 = new List<string> {
                Localizer["DeleteItemAccountConfig"].ToString()
            },
            ListTitle2 = Localizer["ThisAction"].ToString(),
            ListItems2 = new List<string> {
                Localizer["ActionCannotBeUndone"].ToString(),
                Localizer["ActionCannotBeRecovered"].ToString()
            },
            ShowWarning = true,
            WarningMessage = Localizer["DeletionCannotBeUndone"].ToString(),
            ConfirmButtonText = Localizer["Delete"].ToString(),
            ConfirmButtonClass = "btn-danger",
            CancelButtonText = Localizer["Cancel"].ToString()
        };
        
        @await Html.PartialAsync("_ModalTemplate", deleteAccountModal)
    }
}

    @* Mobile/Tablet Cards - bis groÃŸe Bildschirme *@
    <div class="d-lg-none">
        @foreach (var item in Model)
        {
            <div class="card mb-3 account-card @(!item.IsEnabled ? "border-secondary" : "")" data-search="@($"{item.Name} {item.EmailAddress} {item.Username}")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h6 class="card-title mb-0">@item.Name</h6>
                        <form asp-action="ToggleEnabled" asp-route-id="@item.Id" method="post" class="d-inline-flex align-items-center">
                            @Html.AntiForgeryToken()
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" role="switch"
                                       id="enableSwitchMobile_@item.Id"
                                       checked="@item.IsEnabled"
                                       onchange="this.form.submit()"
                                       aria-label="@Localizer["AccountEnabled"]" />
                                <label class="visually-hidden" for="enableSwitchMobile_@item.Id">@Localizer["AccountEnabled"]</label>
                            </div>
                        </form>
                    </div>
                    <p class="card-text small text-muted mb-2">@item.EmailAddress</p>
                    <p class="card-text small mb-2">
                        <strong>@Localizer["Provider"]:</strong>
                        @switch (item.Provider)
                        {
                            case ProviderType.IMAP:
                                <span class="badge bg-primary">IMAP</span>
                                break;
                            case ProviderType.M365:
                                <span class="badge bg-success">Microsoft 365</span>
                                break;
                            case ProviderType.IMPORT:
                                <span class="badge bg-secondary">Import Only</span>
                                break;
                        }
                    </p>
                    <p class="card-text small mb-3">
                        <strong>@Localizer["LastSync"]:</strong>
                        @if (item.LastSync.HasValue)
                        {
                            <span class="utc-timestamp" data-utc-time="@item.LastSync.Value.ToString("yyyy-MM-ddTHH:mm:ss")">
                                @item.LastSync.Value.ToString("g")
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">@Localizer["NotSynced"]</span>
                        }
</p>
                    <p class="card-text small mb-3">
                        <strong>Auto Delete:</strong>
                        @if (item.DeleteAfterDays.HasValue)
                        {
                            <span class="badge bg-warning">@item.DeleteAfterDays.Value days</span>
                        }
                        else
                        {
                            <span class="text-muted">@Localizer["Disabled"]</span>
                        }
                    </p>
                    @* Mobile/Tablet Button Layout *@
                    @{ await Html.RenderPartialAsync("_AccountActionsMenu", item); }
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-envelope-x display-1 text-muted"></i>
                </div>
                <h5 class="text-muted">@Localizer["NoEmailAccountsConfigured"]</h5>
                <p class="text-muted">
                    @Localizer["AddFirstAccount"]
                </p>
                <div class="d-grid gap-2 d-md-flex justify-content-center">
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> @Localizer["AddAccount"]
                    </a>
                    <div class="dropdown">
                        <button class="btn btn-outline-success dropdown-toggle" type="button" id="mobileImportDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-upload"></i> @Localizer["Import"]
                        </button>
                        <ul class="dropdown-menu" aria-labelledby="mobileImportDropdown">
                            <li><a class="dropdown-item" asp-action="ImportMBox"><i class="bi bi-file-earmark-text me-2"></i>@Localizer["ImportMBox"]</a></li>
                            <li><a class="dropdown-item" asp-action="ImportEml"><i class="bi bi-file-earmark-zip me-2"></i>@Localizer["ImportEml"]</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Quick Actions fÃ¼r Mobile wenn Accounts vorhanden *@
    @if (Model.Any())
    {
        <div class="d-lg-none mt-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="row g-2">
                        <div class="col-6">
                            <div class="dropdown">
                                <button class="btn btn-outline-success w-100 dropdown-toggle" type="button" id="mobileQuickImportDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-upload d-block mb-1"></i>
                                    <small>@Localizer["Import"]</small>
                                </button>
                                <ul class="dropdown-menu" aria-labelledby="mobileQuickImportDropdown">
                                    <li><a class="dropdown-item" asp-action="ImportMBox"><i class="bi bi-file-earmark-text me-2"></i>@Localizer["ImportMBox"]</a></li>
                                    <li><a class="dropdown-item" asp-action="ImportEml"><i class="bi bi-file-earmark-zip me-2"></i>@Localizer["ImportEml"]</a></li>
                                </ul>
                            </div>
                        </div>
                        <div class="col-6">
                            <a asp-action="Create" class="btn btn-outline-primary w-100">
                                <i class="bi bi-plus-circle d-block mb-1"></i>
                                <small>@Localizer["AddAccount"]</small>
                            </a>
                        </div>
                        <div class="col-6">
                            <a asp-controller="Emails" asp-action="Index" class="btn btn-outline-info w-100">
                                <i class="bi bi-search d-block mb-1"></i>
                                <small>@Localizer["SearchArchive"]</small>
                            </a>
                        </div>
                        <div class="col-6">
                            <a asp-controller="Emails" asp-action="Jobs" class="btn btn-outline-warning w-100">
                                <i class="bi bi-clock-history d-block mb-1"></i>
                                <small>@Localizer["ViewJobs"]</small>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div id="noAccountMatchHint" class="text-center py-4" style="display: none;">
        <i class="bi bi-search text-muted display-6 d-block mb-2"></i>
        <span class="text-muted">@Localizer["NoAccountsMatch"]</span>
    </div>

    <div class="card mb-3" id="accountPaginationCard" style="display: none;">
        <div class="card-footer">
            <nav>
                <ul class="pagination pagination-sm justify-content-center mb-0" id="accountPagination"></ul>
            </nav>
        </div>
    </div>
</div>
