@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.PstImportViewModel
@{
    ViewData["Title"] = Localizer["ImportPstFileTitle"];
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@Localizer["ImportPstFileTitle"]</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> @Localizer["BackToAccounts"]
        </a>
    </div>

    <div class="alert alert-info mb-4">
        <i class="bi bi-info-circle-fill me-2"></i>
        <strong>@Localizer["PstImportInformation"]</strong>
        <ul class="mb-0 mt-2">
	        <li>@Localizer["SupportedFormatsPst"]</li>
            <li>@string.Format(Localizer["MaximumFileSize"], Model.MaxFileSizeFormatted)</li>
            <li>@Localizer["LargeFilesBackground"]</li>
	        <li>@Localizer["DuplicateEmailsSkipped"]</li>
            <li>@Localizer["PstPreserveFolderInformation"]</li>
        </ul>
    </div>

    <div class="card">
        <div class="card-header bg-light">
            <h5 class="mb-0">@Localizer["UploadAndImportSettings"]</h5>
        </div>
        <div class="card-body">
            <form asp-action="ImportPst" method="post" enctype="multipart/form-data" id="pstImportForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-4">
                    <label asp-for="PstFile" class="form-label">@Localizer["SelectPstFile"]</label>
                    <input asp-for="PstFile" type="file" class="form-control" accept=".pst,.ost" id="pstFileInput">
                    <div class="form-text">@string.Format(Localizer["SupportedFormatsPstWithMax"], Model.MaxFileSizeFormatted)</div>
                    <span asp-validation-for="PstFile" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TargetAccountId" class="form-label">@Localizer["TargetAccount"]</label>
                        <select asp-for="TargetAccountId" asp-items="Model.AvailableAccounts" class="form-select" id="accountSelect">
                            <option value="">@Localizer["PlaceholderSelectAccount"]</option>
                        </select>
                        <span asp-validation-for="TargetAccountId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="TargetFolder" class="form-label">@Localizer["FallbackFolder"]</label>
                        <select asp-for="TargetFolder" class="form-select" id="folderSelect">
                            <option value="">@Localizer["PlaceholderSelectAccountFirst"]</option>
                            <option value="INBOX">INBOX</option>
                        </select>
                        <input type="text" asp-for="TargetFolder" class="form-control" id="folderInput"
                               placeholder="@Localizer["EnterFolderName"]" list="folderList" style="display: none;" />
                        <datalist id="folderList"></datalist>
                        <div class="form-text" id="folderHelpText">
                            @Localizer["FallbackFolderHelpText"]
                        </div>
                        <span asp-validation-for="TargetFolder" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" asp-for="PreserveFolderStructure" id="preserveCheck">
                        <label class="form-check-label" asp-for="PreserveFolderStructure">
                            @Localizer["PreserveFolderStructureLabel"]
                        </label>
                    </div>
                    <div class="form-text">
                        @Localizer["PreserveFolderStructureImportHelp"]
                    </div>
                </div>

                <div id="fileInfo" class="alert alert-secondary" style="display: none;">
                    <h6 class="mb-2">@Localizer["FileInformation"]</h6>
                    <div class="row">
                        <div class="col-md-4">
                            <strong>@Localizer["FileNameLabel"]</strong> <span id="fileName"></span>
                        </div>
                        <div class="col-md-4">
                            <strong>@Localizer["FileSizeLabel"]</strong> <span id="fileSize"></span>
                        </div>
                        <div class="col-md-4">
                            <strong>@Localizer["EstimatedProcessingTime"]</strong> <span id="estimatedTime"></span>
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <strong>@Localizer["Important"]</strong> @Localizer["PstImportWarningText"]
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <div>
                        <button type="submit" class="btn btn-primary" id="submitBtn" disabled>
                            <i class="bi bi-upload me-2"></i>@Localizer["StartImport"]
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary ms-2">@Localizer["Cancel"]</a>
                    </div>
                    <div>
                        <a asp-controller="Emails" asp-action="Jobs" class="btn btn-outline-info">
                            <i class="bi bi-clock-history me-1"></i>@Localizer["ViewImportJobs"]
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            const accountProviders = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AccountProviders));
            const PROVIDER_IMPORT = 2;

            const loc = {
                placeholderSelectAccountFirst: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PlaceholderSelectAccountFirst"].Value)),
                placeholderSelectFolder: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PlaceholderSelectFolder"].Value)),
                loadingFolders: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["LoadingFolders"].Value)),
                errorLoadingFolders: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ErrorLoadingFolders"].Value)),
                enterFolderNameOrSelect: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EnterFolderNameOrSelect"].Value)),
                startingImport: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartingImport"].Value)),
                uploadInProgress: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["UploadInProgress"].Value))
            };

            $('#pstFileInput').on('change', function () {
                const file = this.files[0];
                if (file) {
                    $('#fileName').text(file.name);
                    $('#fileSize').text(formatFileSize(file.size));
                    const estimatedMinutes = Math.ceil((file.size / 1024 / 1024) / 6);
                    $('#estimatedTime').text(estimatedMinutes < 60
                        ? estimatedMinutes + ' minutes'
                        : Math.ceil(estimatedMinutes / 60) + ' hours');
                    $('#fileInfo').show();

                    const maxSize = @Model.MaxFileSize;
                    if (file.size > maxSize) {
                        alert('@string.Format(Localizer["FileSizeExceedsMax"], Model.MaxFileSizeFormatted)');
                        $('#submitBtn').prop('disabled', true);
                        return;
                    }
                    updateSubmitButton();
                } else {
                    $('#fileInfo').hide();
                    $('#submitBtn').prop('disabled', true);
                }
            });

            $('#accountSelect').change(function () {
                const accountId = parseInt($(this).val());
                updateSubmitButton();

                if (accountId) {
                    const isImportAccount = accountProviders[accountId] === PROVIDER_IMPORT;
                    if (isImportAccount) {
                        $('#folderSelect').hide().prop('disabled', true);
                        $('#folderInput').show().prop('disabled', false);
                        $('#folderHelpText').text(loc.enterFolderNameOrSelect);
                        $.ajax({
                            url: '@Url.Action("GetFolders", "MailAccounts")',
                            data: { accountId: accountId },
                            type: 'GET',
                            dataType: 'json',
                            success: function (data) {
                                let options = '';
                                $.each(data, function (i, name) { options += '<option value="' + name + '">'; });
                                $('#folderList').html(options);
                                if (!$('#folderInput').val()) $('#folderInput').val('INBOX');
                                updateSubmitButton();
                            },
                            error: function () {
                                $('#folderList').html('<option value="INBOX">');
                                if (!$('#folderInput').val()) $('#folderInput').val('INBOX');
                                updateSubmitButton();
                            }
                        });
                    } else {
                        $('#folderInput').hide().prop('disabled', true);
                        $('#folderSelect').show().prop('disabled', false);
                        $('#folderSelect').html('<option>' + loc.loadingFolders + '</option>');
                        $.ajax({
                            url: '@Url.Action("GetFolders", "MailAccounts")',
                            data: { accountId: accountId },
                            type: 'GET',
                            dataType: 'json',
                            success: function (data) {
                                let options = '<option value="">' + loc.placeholderSelectFolder + '</option>';
                                let inboxFound = false;
                                $.each(data, function (i, name) {
                                    options += '<option value="' + name + '">' + name + '</option>';
                                    if (name.toUpperCase() === 'INBOX') inboxFound = true;
                                });
                                $('#folderSelect').html(options);
                                if (inboxFound) {
                                    $("#folderSelect option").filter(function () {
                                        return this.value.toUpperCase() === 'INBOX';
                                    }).prop('selected', true);
                                }
                                updateSubmitButton();
                            },
                            error: function () {
                                $('#folderSelect').html('<option value="">' + loc.errorLoadingFolders + '</option><option value="INBOX">INBOX</option>');
                            }
                        });
                    }
                } else {
                    $('#folderSelect').html('<option value="">' + loc.placeholderSelectAccountFirst + '</option>');
                    $('#folderInput').val('').hide();
                    $('#folderSelect').show();
                }
            });

            $('#folderSelect').change(updateSubmitButton);
            $('#folderInput').on('input', updateSubmitButton);

            function updateSubmitButton() {
                const hasFile = $('#pstFileInput')[0].files.length > 0;
                const hasAccount = $('#accountSelect').val() !== '';
                const isImportAccount = $('#folderInput').is(':visible');
                const folderValue = isImportAccount ? $('#folderInput').val() : $('#folderSelect').val();
                const hasFolder = folderValue && folderValue.trim() !== '';
                $('#submitBtn').prop('disabled', !(hasFile && hasAccount && hasFolder));
            }

            function formatFileSize(bytes) {
                const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
                if (bytes === 0) return '0 B';
                const i = Math.floor(Math.log(bytes) / Math.log(1024));
                return Math.round(bytes / Math.pow(1024, i) * 100) / 100 + ' ' + sizes[i];
            }

            $('#pstImportForm').on('submit', function () {
                if ($('#folderInput').is(':visible')) {
                    $('#folderSelect').val($('#folderInput').val());
                }
                $('#submitBtn').html('<i class="bi bi-hourglass-split me-2"></i>' + loc.startingImport).prop('disabled', true);
                $(this).after('<div class="alert alert-info mt-3"><i class="bi bi-clock-history me-2"></i>' + loc.uploadInProgress + '</div>');
            });

            if ($('#accountSelect option').length === 2) {
                $('#accountSelect option:last').prop('selected', true);
                $('#accountSelect').trigger('change');
            }
        });
    </script>
}
