@inject Microsoft.Extensions.Localization.IStringLocalizer<MailArchiver.SharedResource> Localizer
@model MailArchiver.Models.ViewModels.MailAccountViewModel
@{
    ViewData["Title"] = @Localizer["EditEmailAccount"];
}
<div class="container">
    <h1>@Localizer["EditEmailAccount"]</h1>
    <div class="card">
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">@Localizer["AccountName"]</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="EmailAddress" class="form-label">@Localizer["EmailAddress"]</label>
                    <input asp-for="EmailAddress" class="form-control" type="email" />
                    <span asp-validation-for="EmailAddress" class="text-danger"></span>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Provider" class="form-label">@Localizer["Provider"]</label>
                    <select asp-for="Provider" class="form-select">
                        <option value="@ProviderType.IMAP">IMAP</option>
                        <option value="@ProviderType.M365">Microsoft 365</option>
                        <option value="@ProviderType.IMPORT">Import Only</option>
                    </select>
                    <span asp-validation-for="Provider" class="text-danger"></span>
                </div>
                
                <div id="imapSettings">
                    <h4 class="mt-4">@Localizer["IMAPSettings"]</h4>
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label asp-for="ImapServer" class="form-label">@Localizer["IMAPServer"]</label>
                            <input asp-for="ImapServer" class="form-control" />
                            <span asp-validation-for="ImapServer" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="ImapPort" class="form-label">@Localizer["IMAPPort"]</label>
                            <input asp-for="ImapPort" class="form-control" />
                            <span asp-validation-for="ImapPort" class="text-danger"></span>
                        </div>
                    </div>
                    <h4 class="mt-4">@Localizer["Authentication"]</h4>
                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">@Localizer["Username"]</label>
                        <input asp-for="Username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="@Localizer["LeaveEmptyToKeepCurrent"]" />
                        <div class="form-text">@Localizer["LeaveEmptyToKeepCurrent"]</div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="UseSSL" class="form-check-input" />
                        <label asp-for="UseSSL" class="form-check-label">@Localizer["UseSSL"]</label>
                    </div>
                </div>
                
                <div id="microsoft365Settings" style="display: none;">
                    <h4 class="mt-4">@Localizer["Microsoft365Settings"]</h4>
                    
                    <div id="bulkUpdateSuggestion" class="m365-suggestion-box m365-warning" style="display: none;">
                        <h6 class="alert-heading"><i class="bi bi-exclamation-triangle"></i> @Localizer["CredentialChangeDetected"]</h6>
                        <p>@Localizer["ApplyToAllDomainAccountsPrompt"]</p>
                        <div id="affectedAccountsList" class="mb-2">
                            <small>@Localizer["AffectedAccounts"]:</small>
                            <ul id="affectedAccountsUl" class="mb-0"></ul>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="applyToAllDomainAccounts" name="ApplyToAllDomainAccounts" value="true">
                            <label class="form-check-label" for="applyToAllDomainAccounts">
                                @Localizer["ApplyToAllAccounts"]
                            </label>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ClientId" class="form-label">@Localizer["ClientId"]</label>
                        <input asp-for="ClientId" class="form-control" id="ClientIdInput" />
                        <span asp-validation-for="ClientId" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ClientSecret" class="form-label">@Localizer["ClientSecret"]</label>
                        <input asp-for="ClientSecret" class="form-control" type="password" id="ClientSecretInput" placeholder="@Localizer["LeaveEmptyToKeepCurrent"]" />
                        <div class="form-text">@Localizer["LeaveEmptyToKeepCurrent"]</div>
                        <span asp-validation-for="ClientSecret" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="TenantId" class="form-label">@Localizer["TenantId"]</label>
                        <input asp-for="TenantId" class="form-control" id="TenantIdInput" />
                        <span asp-validation-for="TenantId" class="text-danger"></span>
                    </div>
                </div>
                
                <div id="emailDeletionSettings" style="display: none;">
                    <div class="mb-3 form-check">
                        <input asp-for="IsEnabled" class="form-check-input" />
                        <label asp-for="IsEnabled" class="form-check-label">@Localizer["AccountEnabled"]</label>
                        <div class="form-text">@Localizer["DisabledAccountsNotSynced"]</div>
                    </div>
                    
                    <h4 class="mt-4">@Localizer["FolderExclusion"]</h4>
                    <div class="mb-3">
                        <label asp-for="ExcludedFolders" class="form-label">@Localizer["ExcludedFolders"]</label>
                        <textarea asp-for="ExcludedFolders" class="form-control" rows="3" placeholder="@Localizer["EnterFolderNames"]"></textarea>
                        <div class="form-text">@Localizer["EnterFolderNamesText"]</div>
                        <span asp-validation-for="ExcludedFolders" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">@Localizer["AvailableFolders"]</label>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="loadFoldersBtn">
                            <i class="bi bi-folder"></i> @Localizer["LoadAvailableFolders"]
                        </button>
                        <div id="foldersContainer" style="display: none;" class="mt-2">
                            <div class="card">
                                <div class="card-body">
                                    <div id="foldersContent" class="d-flex flex-wrap gap-2">
                                        <!-- Folders will be loaded here -->
                                    </div>
                                </div>
                            </div>
                            <div class="form-text">@Localizer["FoldersOnServer"]</div>
                        </div>
                        <div id="foldersLoading" style="display: none;" class="mt-2">
                            <div class="spinner-border spinner-border-sm" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            @Localizer["LoadingFolders"]
                        </div>
                        <div id="foldersError" style="display: none;" class="mt-2 alert alert-warning">
                            @Localizer["CouldNotLoadFolders"]
                        </div>
                    </div>
                    
                    @if (Model.LastSync.HasValue)
                    {
                        <div class="mb-3">
                            <label asp-for="LastSync" class="form-label">@Localizer["LastSync"]</label>
                            <input value="@Model.LastSync.Value.ToString(System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.ShortDatePattern + " " + System.Globalization.CultureInfo.CurrentUICulture.DateTimeFormat.ShortTimePattern)" class="form-control" readonly />
                        </div>
                    }
                    
                    <h4 class="mt-4">@Localizer["EmailDeletion"]</h4>
                    <div class="mb-3">
                        <label asp-for="DeleteAfterDays" class="form-label">@Localizer["DeleteAfterDays"]</label>
                        <input asp-for="DeleteAfterDays" class="form-control" type="number" min="1" placeholder="@Localizer["LeaveEmptyToDisableAutomaticDeletion"]" />
                        <div class="form-text">@Localizer["AutoDeleteText"]</div>
                        <span asp-validation-for="DeleteAfterDays" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="LocalRetentionDays" class="form-label">@Localizer["LocalRetentionDays"]</label>
                        <input asp-for="LocalRetentionDays" class="form-control" type="number" min="1" placeholder="@Localizer["LeaveEmptyToDisableAutomaticDeletion"]" />
                        <div class="form-text">@Localizer["LocalRetentionInfo"]</div>
                        <span asp-validation-for="LocalRetentionDays" class="text-danger"></span>
                    </div>
                </div>
                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["BackToList"]</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const providerSelect = document.getElementById('Provider');
            const imapSettings = document.getElementById('imapSettings');
            const microsoft365Settings = document.getElementById('microsoft365Settings');
            const emailDeletionSettings = document.getElementById('emailDeletionSettings');
            const loadFoldersBtn = document.getElementById('loadFoldersBtn');
            const foldersContainer = document.getElementById('foldersContainer');
            const foldersContent = document.getElementById('foldersContent');
            const foldersLoading = document.getElementById('foldersLoading');
            const foldersError = document.getElementById('foldersError');
            const clientIdInput = document.getElementById('ClientIdInput');
            const clientSecretInput = document.getElementById('ClientSecretInput');
            const tenantIdInput = document.getElementById('TenantIdInput');
            const bulkUpdateSuggestion = document.getElementById('bulkUpdateSuggestion');
            const affectedAccountsUl = document.getElementById('affectedAccountsUl');
            const applyToAllCheckbox = document.getElementById('applyToAllDomainAccounts');
            const editForm = document.querySelector('form');
            
            console.log('Edit form found:', editForm);
            console.log('Apply checkbox found:', applyToAllCheckbox);
            
            let originalClientId = '@Model.ClientId';
            let originalTenantId = '@Model.TenantId';
            let affectedAccounts = [];
            let bulkUpdateRequested = false;
            
            function toggleSettings() {
                const providerValue = providerSelect.value;
                if (providerValue === '@ProviderType.IMPORT') {
                    imapSettings.style.display = 'none';
                    microsoft365Settings.style.display = 'none';
                    emailDeletionSettings.style.display = 'none';
                } else if (providerValue === '@ProviderType.M365') {
                    imapSettings.style.display = 'none';
                    microsoft365Settings.style.display = 'block';
                    emailDeletionSettings.style.display = 'block';
                } else {
                    imapSettings.style.display = 'block';
                    microsoft365Settings.style.display = 'none';
                    emailDeletionSettings.style.display = 'block';
                }
            }
            
            function checkCredentialChanges() {
                const providerValue = providerSelect.value;
                if (providerValue !== '@ProviderType.M365') {
                    bulkUpdateSuggestion.style.display = 'none';
                    return;
                }
                
                const currentClientId = clientIdInput.value.trim();
                const currentClientSecret = clientSecretInput.value.trim();
                const currentTenantId = tenantIdInput.value.trim();
                
                // Check if any credential has changed
                const credentialsChanged = 
                    (currentClientId && currentClientId !== originalClientId) ||
                    currentClientSecret ||
                    (currentTenantId && currentTenantId !== originalTenantId);
                
                if (credentialsChanged) {
                    checkForDomainAccounts();
                } else {
                    bulkUpdateSuggestion.style.display = 'none';
                }
            }
            
            function checkForDomainAccounts() {
                const emailAddress = '@Model.EmailAddress';
                
                fetch('@Url.Action("CheckM365AccountsForDomain", "MailAccounts")?emailAddress=' + 
                      encodeURIComponent(emailAddress) + '&excludeAccountId=@Model.Id')
                    .then(response => response.json())
                    .then(data => {
                        if (data.exists && data.accounts && data.accounts.length > 0) {
                            affectedAccounts = data.accounts;
                            
                            // Clear and populate affected accounts list
                            affectedAccountsUl.innerHTML = '';
                            data.accounts.forEach(account => {
                                const li = document.createElement('li');
                                li.textContent = account.name + ' (' + account.emailAddress + ')';
                                affectedAccountsUl.appendChild(li);
                            });
                            
                            bulkUpdateSuggestion.style.display = 'block';
                        } else {
                            bulkUpdateSuggestion.style.display = 'none';
                        }
                    })
                    .catch(error => {
                        console.error('Error checking for domain accounts:', error);
                        bulkUpdateSuggestion.style.display = 'none';
                    });
            }
            
            function performBulkUpdate() {
                if (!applyToAllCheckbox.checked || affectedAccounts.length === 0) {
                    console.log('Bulk update skipped - checkbox not checked or no affected accounts');
                    return Promise.resolve();
                }
                
                console.log('Starting bulk update for', affectedAccounts.length, 'accounts');
                console.log('Affected accounts:', affectedAccounts);
                
                const formData = new FormData();
                formData.append('accountId', '@Model.Id');
                formData.append('clientId', clientIdInput.value.trim());
                formData.append('clientSecret', clientSecretInput.value.trim());
                formData.append('tenantId', tenantIdInput.value.trim());
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);
                
                console.log('Bulk update data:', {
                    accountId: '@Model.Id',
                    clientId: clientIdInput.value.trim(),
                    clientSecret: clientSecretInput.value.trim() ? '***' : '(empty)',
                    tenantId: tenantIdInput.value.trim()
                });
                
                return fetch('@Url.Action("UpdateM365CredentialsForDomain", "MailAccounts")', {
                    method: 'POST',
                    body: formData
                })
                .then(response => {
                    console.log('Bulk update response status:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('Bulk update response data:', data);
                    if (data.success) {
                        console.log('Bulk update successful! Updated', data.updatedCount, 'accounts');
                        console.log('Updated accounts:', data.accountNames);
                        return data;
                    } else {
                        console.error('Bulk update failed:', data.message);
                        throw new Error(data.message || 'Bulk update failed');
                    }
                })
                .catch(error => {
                    console.error('Bulk update error:', error);
                    throw error;
                });
            }
            
            // Initial check
            toggleSettings();
            
            // Add event listeners
            providerSelect.addEventListener('change', toggleSettings);
            
            // Monitor credential changes
            if (clientIdInput) {
                clientIdInput.addEventListener('blur', checkCredentialChanges);
            }
            if (clientSecretInput) {
                clientSecretInput.addEventListener('blur', checkCredentialChanges);
            }
            if (tenantIdInput) {
                tenantIdInput.addEventListener('blur', checkCredentialChanges);
            }
            
            // Intercept form submission
            if (editForm) {
                editForm.addEventListener('submit', function(e) {
                    console.log('Form submit triggered!');
                    const providerValue = providerSelect.value;
                    console.log('Provider value:', providerValue);
                    console.log('Checkbox element:', applyToAllCheckbox);
                    console.log('Checkbox checked:', applyToAllCheckbox ? applyToAllCheckbox.checked : 'checkbox not found');
                    console.log('Affected accounts length:', affectedAccounts.length);
                    console.log('Affected accounts:', affectedAccounts);
                    
                    // Check if bulk update is requested
                    if (providerValue === '@ProviderType.M365' && applyToAllCheckbox && applyToAllCheckbox.checked && affectedAccounts.length > 0) {
                        console.log('Bulk update condition MET! Intercepting form submission...');
                        e.preventDefault();
                        e.stopPropagation();
                        
                        // Disable submit button to prevent double submission
                        const submitBtn = editForm.querySelector('button[type="submit"]');
                        if (submitBtn) {
                            submitBtn.disabled = true;
                            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Saving...';
                        }
                        
                        // First save the current account
                        const formData = new FormData(editForm);
                        
                        fetch(editForm.action, {
                            method: 'POST',
                            body: formData
                        })
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Form submission failed');
                            }
                            return response.text(); // Get response as text first
                        })
                        .then(text => {
                            // Now perform bulk update
                            return performBulkUpdate();
                        })
                        .then(bulkResult => {
                            console.log('Bulk update completed successfully');
                            // Redirect to index with success message
                            window.location.href = '@Url.Action("Index", "MailAccounts")';
                        })
                        .catch(error => {
                            console.error('Error during save/bulk update:', error);
                            alert('@Localizer["ErrorSavingChanges"]: ' + error.message);
                            // Re-enable submit button
                            if (submitBtn) {
                                submitBtn.disabled = false;
                                submitBtn.innerHTML = '@Localizer["Save"]';
                            }
                        });
                        
                        return false;
                    }
                });
            }
            
            // Load folders on demand
            if (loadFoldersBtn) {
                loadFoldersBtn.addEventListener('click', function() {
                    // Hide button and error, show loading
                    loadFoldersBtn.style.display = 'none';
                    foldersError.style.display = 'none';
                    foldersLoading.style.display = 'block';
                    foldersContainer.style.display = 'none';
                    
                    // Make AJAX request
                    fetch('@Url.Action("GetFolders", "MailAccounts")?accountId=@Model.Id')
                        .then(response => {
                            if (!response.ok) {
                                throw new Error('Network response was not ok');
                            }
                            return response.json();
                        })
                        .then(folders => {
                            // Clear previous content
                            foldersContent.innerHTML = '';
                            
                            // Add folders as badges
                            if (folders && folders.length > 0) {
                                folders.forEach(folder => {
                                    const badge = document.createElement('span');
                                    badge.className = 'badge bg-light text-dark';
                                    badge.textContent = folder;
                                    foldersContent.appendChild(badge);
                                });
                                
                                // Show container
                                foldersLoading.style.display = 'none';
                                foldersContainer.style.display = 'block';
                            } else {
                                // No folders found
                                foldersLoading.style.display = 'none';
                                foldersError.textContent = '@Localizer["NoFoldersFound"]';
                                foldersError.style.display = 'block';
                                loadFoldersBtn.style.display = 'inline-block';
                            }
                        })
                        .catch(error => {
                            console.error('Error loading folders:', error);
                            foldersLoading.style.display = 'none';
                            foldersError.style.display = 'block';
                            loadFoldersBtn.style.display = 'inline-block';
                        });
                });
            }
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}